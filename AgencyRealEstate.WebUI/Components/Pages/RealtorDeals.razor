@page "/realtor-deals"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator,Manager,Realtor")]
@using System.Net.Http.Json
@inject HttpClient Http

<div class="deals-page">
    <!-- Animated Background -->
    <div class="bg-gradient"></div>
    
    <div class="deals-container">
        <!-- Header -->
        <div class="page-header animate-fade-in">
            <div class="header-left">
                <h1 class="page-title">Портфель <span class="purple-text">сделок</span></h1>
                <p class="page-subtitle">Управление активными и завершёнными операциями</p>
            </div>
            <div class="stats-badge">
                <i class="fas fa-hand-holding-usd"></i>
                <span>@(deals?.Count ?? 0) записей</span>
            </div>
        </div>

        <!-- Filters -->
        @if (deals != null && deals.Any())
        {
            <div class="filters-bar animate-fade-in" style="animation-delay: 0.1s;">
                <div class="filter-group">
                    <button class="filter-btn @(currentFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
                        Все
                    </button>
                    <button class="filter-btn @(currentFilter == "active" ? "active" : "")" @onclick='() => SetFilter("active")'>
                        <span class="filter-dot"></span>
                        Требуют ответа
                    </button>
                    <button class="filter-btn @(currentFilter == "completed" ? "active" : "")" @onclick='() => SetFilter("completed")'>
                        Завершённые
                    </button>
                    <button class="filter-btn @(currentFilter == "cancelled" ? "active" : "")" @onclick='() => SetFilter("cancelled")'>
                        Отменённые
                    </button>
                </div>
                <div class="sort-info">
                    <i class="fas fa-sort-amount-down"></i>
                    <span>Сначала срочные → по дате</span>
                </div>
            </div>
        }

        @if (deals == null)
        {
            <div class="loader-container">
                <div class="premium-spinner"></div>
            </div>
        }
        else if (!FilteredDeals.Any())
        {
            <div class="empty-state animate-fade-in">
                <i class="fas fa-file-contract"></i>
                <h3>Сделок не найдено</h3>
                <p>По выбранному фильтру нет активных записей</p>
            </div>
        }
        else
        {
            <div class="deals-grid">
                @foreach (var deal in FilteredDeals)
                {
                    <div class="deal-card animate-fade-up @(deal.CanComplete ? "urgent" : "")">
                        @if (deal.CanComplete)
                        {
                            <div class="urgent-badge">
                                <i class="fas fa-bell"></i>
                                <span>Требует ответа</span>
                            </div>
                        }
                        
                        <div class="card-header">
                            <div class="property-info">
                                <i class="fas fa-map-marker-alt"></i>
                                <div>
                                    <h3>@deal.PropertyTitle</h3>
                                    <small class="property-address">@deal.PropertyAddress</small>
                                </div>
                            </div>
                            <span class="status-badge @GetStatusClass(deal.StatusName)">
                                @GetStatusName(deal.StatusName)
                            </span>
                        </div>
                        
                        <div class="card-body">
                            <div class="buyer-info">
                                <i class="fas fa-user"></i>
                                <span class="buyer-name">@deal.BuyerName</span>
                            </div>
                            
                            <div class="deal-meta">
                                <div class="meta-item">
                                    <i class="fas fa-file-contract"></i>
                                    <span>@deal.DealTypeName</span>
                                </div>
                                <div class="meta-item">
                                    <i class="fas fa-calendar"></i>
                                    <span>@deal.DealDate.ToString("dd.MM.yyyy")</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">
                            <div class="amount-display">
                                <span class="amount-label">Сумма</span>
                                <span class="amount-value">@(deal.Amount?.ToString("N0") ?? "—") ₽</span>
                            </div>
                            
                            @if (deal.CanComplete)
                            {
                                <div class="action-group">
                                    <button class="btn-complete" @onclick="() => CompleteDeal(deal.DealId)" title="Завершить">
                                        <i class="fas fa-check"></i>
                                    </button>
                                    <button class="btn-reject" @onclick="() => RejectDeal(deal.DealId)" title="Отклонить">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <button class="btn-edit" @onclick="() => OpenEditModal(deal)" title="Редактировать">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span class="deal-closed">Завершено</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Edit Modal -->
@if (editDeal != null)
{
    <div class="modal-backdrop" @onclick="CloseEditModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Редактирование сделки</h2>
                <button class="btn-close" @onclick="CloseEditModal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="deal-preview">
                    <strong>@editDeal.PropertyTitle</strong>
                    <small>@editDeal.PropertyAddress</small>
                </div>
                
                <div class="form-group">
                    <label>Тип сделки</label>
                    <select @bind="editModel.DealTypeId" class="form-select">
                        <option value="1">Покупка</option>
                        <option value="2">Аренда</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Сумма сделки (₽)</label>
                    <input type="number" @bind="editModel.Amount" class="form-input" placeholder="0" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseEditModal">Отмена</button>
               <button class="btn-save" @onclick="SaveEdit">
    <i class="fas fa-paper-plane"></i> Сохранить и отправить клиенту
</button>
            </div>
        </div>
    </div>
}

<style>
    :root {
        --primary: #8b5cf6;
        --primary-dark: #7c3aed;
        --primary-light: #a78bfa;
        --primary-bg: #f5f3ff;
        --bg-page: #f8fafc;
        --bg-card: #ffffff;
        --text-dark: #0f172a;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --success: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
        --urgent: #fef3c7;
        --urgent-border: #fcd34d;
        --shadow: 0 4px 6px rgba(0,0,0,0.05);
        --shadow-lg: 0 10px 30px rgba(139, 92, 246, 0.15);
    }

    .deals-page {
        min-height: 100vh;
        background: var(--bg-page);
        padding: 100px 40px 40px;
        position: relative;
    }

    .bg-gradient {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
    }

    .deals-container {
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
        gap: 20px;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
        color: var(--text-dark);
    }

    .purple-text {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        color: var(--text-muted);
        margin: 4px 0 0;
        font-size: 1.1rem;
    }

    .stats-badge {
        background: white;
        border: 2px solid rgba(139, 92, 246, 0.2);
        padding: 12px 24px;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--primary);
        font-weight: 700;
        box-shadow: var(--shadow);
    }

    /* Filters */
    .filters-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        padding: 16px 24px;
        background: white;
        border-radius: 16px;
        box-shadow: var(--shadow);
        flex-wrap: wrap;
        gap: 16px;
    }

    .filter-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 10px 20px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text-muted);
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .filter-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .filter-dot {
        width: 8px;
        height: 8px;
        background: var(--warning);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .sort-info {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .sort-info i {
        color: var(--primary);
    }

    /* Deals Grid */
    .deals-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
        gap: 24px;
    }

    .deal-card {
        background: var(--bg-card);
        border-radius: 20px;
        border: 2px solid var(--border);
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: var(--shadow);
        position: relative;
    }

    .deal-card:hover {
        border-color: var(--primary);
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .deal-card.urgent {
        border-color: var(--urgent-border);
        background: var(--urgent);
    }

    .deal-card.urgent:hover {
        border-color: var(--warning);
        box-shadow: 0 10px 30px rgba(245, 158, 11, 0.2);
    }

    .urgent-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background: var(--warning);
        color: #92400e;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 6px;
        z-index: 2;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }

    .card-header {
        padding: 20px 28px;
        background: var(--primary-bg);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        border-bottom: 1px solid var(--border);
    }

    .property-info {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }

    .property-info i {
        color: var(--primary);
        margin-top: 4px;
        flex-shrink: 0;
    }

    .property-info h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        color: var(--text-dark);
        line-height: 1.2;
    }

    .property-address {
        font-size: 0.85rem;
        color: var(--text-muted);
        display: block;
        margin-top: 4px;
    }

    .status-badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .status-badge.inprogress {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
    }

    .status-badge.completed {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .status-badge.cancelled {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }

    .card-body {
        padding: 28px;
    }

    .buyer-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: var(--bg-page);
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .buyer-info i {
        color: var(--primary);
        font-size: 1.1rem;
    }

    .buyer-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .deal-meta {
        display: flex;
        gap: 24px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .meta-item i {
        color: var(--primary);
        width: 16px;
    }

    .card-footer {
        padding: 20px 28px;
        background: var(--bg-page);
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .amount-display {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .amount-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .amount-value {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--text-dark);
    }

    .action-group {
        display: flex;
        gap: 8px;
    }

    .btn-complete, .btn-reject, .btn-edit {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 1rem;
    }

    .btn-complete {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }
    .btn-complete:hover {
        background: var(--success);
        color: white;
        transform: translateY(-2px);
    }

    .btn-reject {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }
    .btn-reject:hover {
        background: var(--danger);
        color: white;
        transform: translateY(-2px);
    }

    .btn-edit {
        background: rgba(139, 92, 246, 0.1);
        color: var(--primary);
    }
    .btn-edit:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
    }

    .deal-closed {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    /* Modal */
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.3s;
    }

    .modal-content {
        background: white;
        border-radius: 24px;
        width: 90%;
        max-width: 500px;
        overflow: hidden;
        animation: slideUp 0.3s;
        box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    }

    .modal-header {
        padding: 24px 32px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h2 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    .btn-close {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--text-muted);
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .btn-close:hover {
        background: var(--bg-page);
        color: var(--text-dark);
    }

    .modal-body {
        padding: 32px;
    }

    .deal-preview {
        background: var(--primary-bg);
        border: 1px solid rgba(139, 92, 246, 0.2);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 24px;
    }

    .deal-preview strong {
        display: block;
        color: var(--text-dark);
        font-size: 1.1rem;
        margin-bottom: 4px;
    }

    .deal-preview small {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
    }

    .form-select, .form-input {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid var(--border);
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s;
        background: white;
        color: var(--text-dark);
    }

    .form-select:focus, .form-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
    }

    .modal-footer {
        padding: 20px 32px;
        background: var(--bg-page);
        border-top: 1px solid var(--border);
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-cancel {
        padding: 12px 24px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text-muted);
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-cancel:hover {
        border-color: var(--text-dark);
        color: var(--text-dark);
    }

    .btn-save {
        padding: 12px 24px;
        border: none;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    /* Loader & Empty */
    .loader-container {
        text-align: center;
        padding: 100px 20px;
    }

    .premium-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid var(--primary-bg);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s infinite linear;
    }

    .empty-state {
        text-align: center;
        padding: 100px 40px;
        background: white;
        border-radius: 24px;
        border: 2px dashed var(--border);
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--primary);
        opacity: 0.3;
        margin-bottom: 24px;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 12px;
    }

    .empty-state p {
        color: var(--text-muted);
        font-size: 1.05rem;
        margin: 0;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .animate-fade-in {
        animation: fadeIn 0.6s ease forwards;
    }

    .animate-fade-up {
        opacity: 0;
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .deals-page {
            padding: 80px 20px 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .page-title {
            font-size: 1.8rem;
        }

        .filters-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-group {
            justify-content: center;
        }

        .deals-grid {
            grid-template-columns: 1fr;
        }

        .card-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .card-footer {
            flex-direction: column;
            gap: 16px;
            align-items: stretch;
        }

        .action-group {
            justify-content: center;
        }
    }
</style>

@code {
    private List<DealDto>? deals;
    private string currentFilter = "all";
    private DealDto? editDeal;
    private UpdateDealRequest editModel = new();

    private IEnumerable<DealDto> FilteredDeals
    {
        get
        {
            if (deals == null) return new List<DealDto>();

            var filtered = currentFilter switch
            {
                "active" => deals.Where(d => d.CanComplete),
                "completed" => deals.Where(d => d.StatusName == "Completed"),
                "cancelled" => deals.Where(d => d.StatusName == "Cancelled"),
                _ => deals
            };

            // Сортировка: сначала срочные (CanComplete = true), затем по дате (новые сверху)
            return filtered
                .OrderByDescending(d => d.CanComplete ? 1 : 0)
                .ThenByDescending(d => d.DealDate);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDeals();
    }

    private async Task LoadDeals()
    {
        try
        {
            await Task.Delay(300);
            deals = await Http.GetFromJsonAsync<List<DealDto>>("deals/assigned");
        }
        catch
        {
            deals = new();
        }
    }

    private void SetFilter(string filter)
    {
        currentFilter = filter;
    }

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "inprogress" => "inprogress",
        "completed" => "completed",
        "cancelled" => "cancelled",
        _ => ""
    };

    private string GetStatusName(string status) => status switch
    {
        "InProgress" => "В процессе",
        "Completed" => "Завершена",
        "Cancelled" => "Отменена",
        _ => "Неизвестно"
    };

    private void OpenEditModal(DealDto deal)
    {
        editDeal = deal;
        editModel = new UpdateDealRequest 
        { 
            Amount = deal.Amount, 
            DealTypeId = deal.DealTypeId 
        };
    }

    private void CloseEditModal() => editDeal = null;

    private async Task SaveEdit()
    {
        if (editDeal == null) return;
        try
        {
            var response = await Http.PutAsJsonAsync($"deals/{editDeal.DealId}", editModel);
            if (response.IsSuccessStatusCode)
            {
                await LoadDeals();
                CloseEditModal();
            }
        }
        catch { }
    }

    private async Task CompleteDeal(int id)
    {
        try
        {
            var response = await Http.PutAsync($"deals/{id}/complete", null);
            if (response.IsSuccessStatusCode) await LoadDeals();
        }
        catch { }
    }

    private async Task RejectDeal(int id)
    {
        try
        {
            var response = await Http.PutAsync($"deals/{id}/reject", null);
            if (response.IsSuccessStatusCode) await LoadDeals();
        }
        catch { }
    }

    public class DealDto
    {
        public int DealId { get; set; }
        public DateTime DealDate { get; set; }
        public decimal? Amount { get; set; }
        public string PropertyAddress { get; set; } = "";
        public string PropertyTitle { get; set; } = "";
        public string BuyerName { get; set; } = "";
        public string StatusName { get; set; } = "";
        public string DealTypeName { get; set; } = "";
        public bool CanComplete { get; set; }
        public int DealTypeId { get; set; }
    }

    public class UpdateDealRequest
    {
        public int? DealTypeId { get; set; }
        public decimal? Amount { get; set; }
    }
