@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator")]
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="admin-dashboard">
    <!-- Header -->
    <div class="dashboard-header fade-in-up" style="animation-delay: 0s;">
        <div class="header-content">
            <h1 class="page-title">Управление <span class="purple-text">Командой</span></h1>
            <p class="page-subtitle">Контроль доступа и управление привилегиями сотрудников</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">
            <i class="fas fa-plus"></i>
            <span>Новый сотрудник</span>
        </button>
    </div>

    @if (users == null)
    {
        <div class="loader-container">
            <div class="premium-spinner"></div>
            <p style="margin-top: 16px; color: var(--text-muted);">Загрузка данных...</p>
        </div>
    }
    else
    {
        <!-- Staff Grid -->
        <div class="staff-grid">
            @foreach (var user in users)
            {
                <div class="staff-card animate-fade-up" 
                     style="animation-delay: @(0.1 + users.IndexOf(user) * 0.05)s;"
                     @onclick="() => OpenEditModal(user)">
                    
                    <div class="card-header">
                        <div class="status-dot @(user.Role.ToLower())"></div>
                        <span class="role-badge @(user.Role.ToLower())">@user.Role</span>
                    </div>
                    
                    <div class="card-body">
                        <div class="user-avatar">
                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                            {
                                <img src="@user.AvatarUrl" alt="@user.Login" class="avatar-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
                                <div class="avatar-placeholder" style="display: none;">
                                    @user.Login.Substring(0, 1).ToUpper()
                                </div>
                            }
                            else
                            {
                                <div class="avatar-placeholder">
                                    @user.Login.Substring(0, 1).ToUpper()
                                </div>
                            }
                            <div class="online-indicator @(user.IsActive ? "active" : "inactive")"></div>
                        </div>
                        
                        <div class="user-info">
                            <h3 class="user-name">@user.Login</h3>
                            <p class="user-email">@user.Email</p>
                            <span class="user-id">ID: #@user.UserId</span>
                        </div>
                    </div>
                    
                    <div class="card-footer">
                        <span>Управление доступом</span>
                        <i class="fas fa-chevron-right"></i>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Unified Modal -->
@if (selectedUser != null || isAdding)
{
    <div class="modal-backdrop animate-fade-in" @onclick="CloseModals">
        <div class="modal-card animate-modal-in" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>
                    <i class="fas @(isAdding ? "fa-user-plus" : "fa-user-cog") purple-text me-2"></i>
                    @(isAdding ? "Регистрация сотрудника" : "Настройки доступа")
                </h3>
                <button class="close-btn" @onclick="CloseModals">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="modal-body">
                @if (isAdding)
                {
                    <!-- Add User Form -->
                    <EditForm Model="addModel" OnValidSubmit="CreateUser">
                        <DataAnnotationsValidator />
                        <div class="form-grid">
                            <div class="form-group full">
                                <label>Логин в системе</label>
                                <InputText @bind-Value="addModel.Login" class="form-input" placeholder="Введите логин" />
                                <ValidationMessage For="@(() => addModel.Login)" class="error-message" />
                            </div>
                            
                            <div class="form-group">
                                <label>Email</label>
                                <InputText @bind-Value="addModel.Email" class="form-input" placeholder="example@company.ru" />
                                <ValidationMessage For="@(() => addModel.Email)" class="error-message" />
                            </div>
                            
                            <div class="form-group">
                                <label>Пароль</label>
                                <InputText @bind-Value="addModel.Password" type="password" class="form-input" placeholder="••••••••" />
                                <ValidationMessage For="@(() => addModel.Password)" class="error-message" />
                            </div>
                            
                            <div class="form-group full">
                                <label>Уровень доступа</label>
                                <select @bind="addModel.RoleId" class="form-input">
                                    <option value="" disabled selected>Выберите роль...</option>
                                    <option value="1">Администратор</option>
                                    <option value="2">Менеджер</option>
                                    <option value="3">Риелтор</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="modal-actions">
                            <button type="button" class="btn-cancel" @onclick="CloseModals">
                                <i class="fas fa-times"></i> Отмена
                            </button>
                            <button type="submit" class="btn-save">
                                <i class="fas fa-check"></i> Создать аккаунт
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedUser != null)
                {
                    <!-- Edit User Form -->
                    <div class="profile-view">
                        <div class="profile-header">
                            <div class="avatar-large-wrapper">
                                @if (!string.IsNullOrEmpty(selectedUser.AvatarUrl))
                                {
                                    <img src="@selectedUser.AvatarUrl" alt="@selectedUser.Login" class="avatar-large-image" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'" />
                                }
                                <div class="avatar-large" style="@(!string.IsNullOrEmpty(selectedUser.AvatarUrl) ? "display: none;" : "")">
                                    @selectedUser.Login.Substring(0, 1).ToUpper()
                                </div>
                            </div>
                            <div class="profile-status">
                                <span class="status-badge @(selectedUser.IsActive ? "active" : "inactive")">
                                    @(selectedUser.IsActive ? "Активен" : "Заблокирован")
                                </span>
                            </div>
                        </div>
                        
                        <EditForm Model="editModel" OnValidSubmit="SaveChanges">
                            <div class="form-grid">
                                <div class="form-group full">
                                    <label>Логин</label>
                                    <InputText @bind-Value="editModel.NewLogin" class="form-input" />
                                </div>
                                
                                <div class="form-group full">
                                    <label>Новый пароль</label>
                                    <InputText @bind-Value="editModel.NewPassword" type="password" class="form-input" placeholder="Оставьте пустым, чтобы не менять" />
                                </div>
                            </div>
                            
                            <div class="modal-actions">
                                <button type="button" class="btn-danger" @onclick="() => ToggleActive(selectedUser)">
                                    <i class="fas @(selectedUser.IsActive ? "fa-lock" : "fa-unlock")"></i>
                                    @(selectedUser.IsActive ? "Заблокировать" : "Разблокировать")
                                </button>
                                <button type="submit" class="btn-save">
                                    <i class="fas fa-save"></i> Сохранить
                                </button>
                            </div>
                        </EditForm>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    :root {
        --primary: #7c3aed;
        --primary-light: #8b5cf6;
        --primary-dark: #6d28d9;
        --primary-bg: #f5f3ff;
        --bg-page: #f8fafc;
        --bg-card: #ffffff;
        --text-dark: #0f172a;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --success: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
        --shadow: 0 4px 6px rgba(0,0,0,0.07);
        --shadow-lg: 0 10px 30px rgba(124, 58, 237, 0.15);
    }

    .admin-dashboard {
        padding: 100px 40px 40px;
        background: var(--bg-page);
        min-height: 100vh;
        color: var(--text-dark);
        font-family: 'Inter', system-ui, sans-serif;
    }

    /* Header */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 40px;
        gap: 20px;
    }

    .header-content h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0 0 8px;
        letter-spacing: -0.5px;
    }

    .purple-text {
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 1.1rem;
        margin: 0;
    }

    .btn-primary {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
    }

    /* Staff Grid */
    .staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .staff-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
        box-shadow: var(--shadow);
    }

    .staff-card:hover {
        border-color: var(--primary);
        transform: translateY(-6px);
        box-shadow: var(--shadow-lg);
    }

    .card-header {
        padding: 16px 20px;
        background: var(--primary-bg);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border);
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }
    .status-dot.administrator { background: var(--primary); }
    .status-dot.manager { background: #3b82f6; }
    .status-dot.realtor { background: var(--success); }

    .role-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .role-badge.administrator { background: var(--primary); color: white; }
    .role-badge.manager { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .role-badge.realtor { background: rgba(16, 185, 129, 0.15); color: var(--success); }

    .card-body {
        padding: 24px;
        display: flex;
        gap: 16px;
        align-items: center;
    }

    .user-avatar {
        position: relative;
        flex-shrink: 0;
    }

    .avatar-placeholder {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    .avatar-image {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        object-fit: cover;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    .online-indicator {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid white;
    }
    .online-indicator.active { background: var(--success); }
    .online-indicator.inactive { background: var(--text-muted); }

    .user-info {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 4px;
    }

    .user-email {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin: 0 0 4px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-id {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-family: monospace;
    }

    .card-footer {
        padding: 14px 20px;
        background: var(--bg-page);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--primary);
        border-top: 1px solid var(--border);
    }

    .card-footer i {
        transition: transform 0.3s;
    }

    .staff-card:hover .card-footer i {
        transform: translateX(4px);
    }

    /* Loader */
    .loader-container {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 100px;
    }

    .premium-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid var(--primary-bg);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s infinite linear;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    /* Modal Styles */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .modal-card {
        background: white;
        border-radius: 24px;
        width: 100%;
        max-width: 520px;
        max-height: 90vh;
        overflow: hidden;
        box-shadow: 0 25px 80px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
        border: 1px solid var(--border);
    }

    .modal-header {
        padding: 24px 32px;
        background: var(--bg-page);
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h3 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .close-btn {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: none;
        background: var(--bg-page);
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .close-btn:hover {
        background: var(--danger);
        color: white;
        transform: rotate(90deg);
    }

    .modal-body {
        padding: 32px;
        overflow-y: auto;
        color: var(--text-dark);
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .form-group.full {
        grid-column: 1 / -1;
    }

    .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 10px;
        background: white;
        color: var(--text-dark);
        font-size: 0.95rem;
        transition: all 0.3s;
    }

    .form-input::placeholder {
        color: var(--text-muted);
    }

    .form-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
    }

    .error-message {
        color: var(--danger);
        font-size: 0.8rem;
        margin-top: 4px;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
    }

    .btn-cancel {
        padding: 10px 24px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text-muted);
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-cancel:hover {
        border-color: var(--text-dark);
        color: var(--text-dark);
    }

    .btn-save {
        padding: 10px 24px;
        border: none;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
    }

    .btn-danger {
        padding: 10px 24px;
        border: 2px solid var(--danger);
        background: white;
        color: var(--danger);
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-danger:hover {
        background: var(--danger);
        color: white;
    }

    /* Profile View */
    .profile-view {
        text-align: center;
    }

    .profile-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
    }

    .avatar-large-wrapper {
        position: relative;
    }

    .avatar-large {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        box-shadow: 0 4px 16px rgba(124, 58, 237, 0.3);
    }

    .avatar-large-image {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        object-fit: cover;
        box-shadow: 0 4px 16px rgba(124, 58, 237, 0.3);
    }

    .status-badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .status-badge.active {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .status-badge.inactive {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger);
    }

    /* Animations */
    .animate-fade-in {
        animation: fadeIn 0.3s ease forwards;
    }

    .animate-modal-in {
        animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-fade-up {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes modalSlideUp {
        from {
            opacity: 0;
            transform: translateY(40px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes fadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Utilities */
    .purple-text { color: var(--primary) !important; }
    .me-2 { margin-right: 0.5rem !important; }

    /* Responsive */
    @@media (max-width: 768px) {
        .admin-dashboard {
            padding: 100px 20px 20px;
        }
        
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }
        
        .header-content h1 {
            font-size: 1.8rem;
        }
        
        .staff-grid {
            grid-template-columns: 1fr;
        }
        
        .form-grid {
            grid-template-columns: 1fr;
        }
        
        .modal-card {
            max-height: 95vh;
        }
    }
</style>

@code {
    private List<UserDto>? users;
    private UserDto? selectedUser;
    private bool isAdding = false;
    private UpdateUserRequest editModel = new();
    private AddUserRequest addModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            await Task.Delay(300);
            users = await Http.GetFromJsonAsync<List<UserDto>>("admin/users");
        }
        catch
        {
            users = new List<UserDto>();
        }
    }

    private void OpenEditModal(UserDto user)
    {
        selectedUser = user;
        isAdding = false;
        editModel = new UpdateUserRequest { NewLogin = user.Login };
    }

    private void OpenAddModal()
    {
        isAdding = true;
        selectedUser = null;
        addModel = new AddUserRequest();
    }

    private void CloseModals()
    {
        selectedUser = null;
        isAdding = false;
    }

    private async Task SaveChanges()
    {
        if (selectedUser == null) return;
        try
        {
            var response = await Http.PutAsJsonAsync($"admin/users/{selectedUser.UserId}", editModel);
            if (response.IsSuccessStatusCode)
            {
                await LoadUsers();
                CloseModals();
            }
        }
        catch { }
    }

    private async Task ToggleActive(UserDto user)
    {
        var request = new UpdateUserRequest { IsActive = !user.IsActive };
        await Http.PutAsJsonAsync($"admin/users/{user.UserId}", request);
        user.IsActive = !user.IsActive;
        StateHasChanged();
    }

    private async Task CreateUser()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("admin/users", addModel);
            if (response.IsSuccessStatusCode)
            {
                await LoadUsers();
                CloseModals();
            }
        }
        catch { }
    }

    public class UserDto
    {
        public int UserId { get; set; }
        public string Login { get; set; } = "";
        public string Email { get; set; } = "";
        public string? AvatarUrl { get; set; }  
        public string Role { get; set; } = "";
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class UpdateUserRequest
    {
        public string? NewLogin { get; set; }
        public string? NewPassword { get; set; }
        public bool? IsActive { get; set; }
    }

    public class AddUserRequest
    {
        [Required(ErrorMessage = "Логин обязателен")]
        public string Login { get; set; } = "";
        [Required(ErrorMessage = "Пароль обязателен")]
        public string Password { get; set; } = "";
        [EmailAddress(ErrorMessage = "Введите корректный email")]
        public string Email { get; set; } = "";
        public int? RoleId { get; set; }
    }
}