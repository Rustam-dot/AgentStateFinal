@page "/reports"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator,Manager")]
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<div class="reports-dashboard">
    <div class="dashboard-header mb-4 fade-in-up" style="animation-delay: 0s;">
        <div class="header-text">
            <h1>Отчёты и <span class="text-primary">аналитика</span></h1>
            <p>Обзор эффективности бизнеса</p>
        </div>
    </div>

    @if (report == null)
    {
        <div class="loader-container">
            <div class="premium-spinner"></div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-3" @onclick="() => ShowObjectsModal(null)" style="cursor:pointer;">
                <div class="stat-card-v2 fade-in-up" style="animation-delay: 0.1s;">
                    <div class="card-icon-box"><i class="fas fa-building"></i></div>
                    <div class="card-info">
                        <span class="v-number">@report.Properties.Total</span>
                        <span class="v-label">Всего объектов</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3" @onclick='() => ShowObjectsModal("Available")' style="cursor:pointer;">
                <div class="stat-card-v2 fade-in-up" style="animation-delay: 0.2s;">
                    <div class="card-icon-box primary-icon"><i class="fas fa-check-circle"></i></div>
                    <div class="card-info">
                        <span class="v-number">@report.Properties.Available</span>
                        <span class="v-label">Доступно</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3" @onclick='() => ShowObjectsModal("Sold")' style="cursor:pointer;">
                <div class="stat-card-v2 fade-in-up" style="animation-delay: 0.3s;">
                    <div class="card-icon-box"><i class="fas fa-chart-line"></i></div>
                    <div class="card-info">
                        <span class="v-number">@report.Properties.Sold</span>
                        <span class="v-label">Продано</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card-v2 fade-in-up" style="animation-delay: 0.4s;">
                    <div class="card-icon-box primary-icon"><i class="fas fa-dollar-sign"></i></div>
                    <div class="card-info">
                        <span class="v-number">@(report.MonthlyRevenue.LastOrDefault()?.TotalAmount.ToString("N0") ?? "0") ₽</span>
                        <span class="v-label">Общая выручка</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="chart-glass-card fade-in-up" style="animation-delay: 0.5s;">
                    <div class="chart-header">
                        <i class="fas fa-dollar-sign text-primary me-2"></i> Выручка по месяцам
                    </div>
                    <div class="canvas-container">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="chart-glass-card fade-in-up" style="animation-delay: 0.6s;">
                    <div class="chart-header">
                        <i class="fas fa-exchange-alt text-primary me-2"></i> Количество сделок
                    </div>
                    <div class="canvas-container">
                        <canvas id="transactionsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="top-performers-section fade-in-up" style="animation-delay: 0.7s;">
            <div class="section-title">
                <i class="fas fa-award text-primary me-2"></i> Лучшие риелторы
            </div>
            <div class="performers-list">
                @foreach (var r in report.Realtors.List)
                {
                    <div class="performer-horizontal-item animate-hover" @onclick='() => ShowRealtorDeals(r.RealtorName)' style="cursor:pointer;">
                        <div class="rank-badge">@(report.Realtors.List.IndexOf(r) + 1)</div>
                        <div class="p-avatar">@r.RealtorName[0]</div>
                        <div class="p-details">
                            <span class="p-name">@r.RealtorName</span>
                            <span class="p-sub">@r.DealsCount сделок</span>
                        </div>
                        <div class="p-revenue">
                            <span class="p-amount">@r.TotalAmount.ToString("N0") ₽</span>
                            <span class="p-sub">доход</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (showObjectsModal)
{
    <div class="modal-backdrop animate-fade-in" @onclick="CloseModals">
        <div class="modal-card animate-modal-in" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><i class="fas fa-list me-2 text-primary"></i> @modalTitle</h3>
                <button class="close-btn" @onclick="CloseModals">×</button>
            </div>
            <div class="modal-body">
                @if (modalObjects != null && modalObjects.Any())
                {
                    <div class="table-responsive">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th @onclick='() => SortList(modalObjects, "Id", x => x.PropertyId)' style="cursor:pointer;">
                                        ID <i class="@GetSortIcon("Id")"></i>
                                    </th>
                                    <th @onclick='() => SortList(modalObjects, "Address", x => x.Address)' style="cursor:pointer;">
                                        Адрес <i class="@GetSortIcon("Address")"></i>
                                    </th>
                                    <th @onclick='() => SortList(modalObjects, "Price", x => x.Price)' style="cursor:pointer;">
                                        Цена <i class="@GetSortIcon("Price")"></i>
                                    </th>
                                    <th @onclick='() => SortList(modalObjects, "Status", x => x.StatusName)' style="cursor:pointer;">
                                        Статус <i class="@GetSortIcon("Status")"></i>
                                    </th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var obj in modalObjects)
                                {
                                    <tr class="@(editingProperty?.PropertyId == obj.PropertyId ? "d-none" : "") animate-row-in">
                                        <td class="text-primary fw-bold">#@obj.PropertyId</td>
                                        <td><div class="text-truncate" style="max-width: 300px; font-size: 0.9rem;">@obj.Address</div></td>
                                        <td class="fw-bold">@obj.Price?.ToString("N0") ₽</td>
                                        <td>
                                            <span class="status-badge @(obj.StatusName == "Available" ? "status-available" : "status-sold")">
                                                @(obj.StatusName == "Available" ? "ДОСТУПНО" : "ПРОДАНО")
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn-icon btn-edit" @onclick="() => StartEdit(obj)" title="Редактировать">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn-icon btn-delete" @onclick="() => DeleteProperty(obj)" title="Удалить">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>

                                    @if (editingProperty?.PropertyId == obj.PropertyId)
                                    {
                                        <tr class="animate-slide-down">
                                            <td colspan="5" class="edit-panel">
                                                <div class="edit-content">
                                                    <h5 class="edit-title mb-4">
                                                        <i class="fas fa-pen-nib me-2 text-primary"></i> 
                                                        Редактирование объекта #@obj.PropertyId
                                                    </h5>
                                                    <EditForm Model="editModel" OnValidSubmit="SaveEdit">
                                                        <div class="edit-grid">
                                                            <div class="edit-field full">
                                                                <label>Название объекта</label>
                                                                <InputText @bind-Value="editModel.Title" class="form-input" placeholder="Введите название" />
                                                            </div>
                                                            <div class="edit-field full">
                                                                <label>Адрес объекта</label>
                                                                <InputText @bind-Value="editModel.Address" class="form-input" placeholder="Введите адрес" />
                                                            </div>
                                                            <div class="edit-field">
                                                                <label>Стоимость (₽)</label>
                                                                <InputNumber @bind-Value="editModel.Price" class="form-input" placeholder="0" />
                                                            </div>
                                                            <div class="edit-field">
                                                                <label>Комнат</label>
                                                                <InputNumber @bind-Value="editModel.Rooms" class="form-input" />
                                                            </div>
                                                            <div class="edit-field">
                                                                <label>Ванных</label>
                                                                <InputNumber @bind-Value="editModel.Bathrooms" class="form-input" />
                                                            </div>
                                                            <div class="edit-field">
                                                                <label>Площадь (м²)</label>
                                                                <InputNumber @bind-Value="editModel.TotalArea" class="form-input" />
                                                            </div>
                                                            <div class="edit-field">
                                                                <label>Этаж</label>
                                                                <InputNumber @bind-Value="editModel.Floor" class="form-input" />
                                                            </div>
                                                            <div class="edit-field full">
                                                                <label>Описание</label>
                                                                <InputTextArea @bind-Value="editModel.Description" class="form-input textarea" rows="2" placeholder="Описание объекта..." />
                                                            </div>
                                                        </div>
                                                        <div class="edit-actions">
                                                            <button type="button" class="btn-cancel" @onclick="CancelEdit">
                                                                <i class="fas fa-times me-1"></i> Отмена
                                                            </button>
                                                            <button type="submit" class="btn-save">
                                                                <i class="fas fa-check me-1"></i> Сохранить
                                                            </button>
                                                        </div>
                                                    </EditForm>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state animate-fade-in">
                        <i class="fas fa-folder-open"></i>
                        <p>Нет объектов для отображения</p>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (showRealtorModal)
{
    <div class="modal-backdrop animate-fade-in" @onclick="CloseModals">
        <div class="modal-card modal-card-large animate-modal-in" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div>
                    <span class="modal-subtitle text-uppercase">Аналитика агента</span>
                    <h3>@currentRealtorName</h3>
                </div>
                <button class="close-btn" @onclick="CloseModals">×</button>
            </div>
            <div class="modal-body">
                @if (realtorDeals != null && realtorDeals.Any())
                {
                    <div class="table-responsive">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th @onclick='() => SortList(realtorDeals, "DealId", x => x.DealId)' style="cursor:pointer;">
                                        ID <i class="@GetSortIcon("DealId")"></i>
                                    </th>
                                    <th @onclick='() => SortList(realtorDeals, "Property", x => x.PropertyAddress)' style="cursor:pointer;">
                                        Объект <i class="@GetSortIcon("Property")"></i>
                                    </th>
                                    <th @onclick='() => SortList(realtorDeals, "Amount", x => x.Amount)' style="cursor:pointer;">
                                        Сумма <i class="@GetSortIcon("Amount")"></i>
                                    </th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var deal in realtorDeals)
                                {
                                    <tr class="animate-row-in">
                                        <td class="text-primary fw-bold">#@deal.DealId</td>
                                        <td><div class="text-truncate" style="max-width: 300px; font-size: 0.85rem;">@deal.PropertyAddress</div></td>
                                        <td class="fw-bold">@deal.Amount?.ToString("N0") ₽</td>
                                        <td>
                                            <span class="status-badge status-completed">ВЫПОЛНЕНО</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state animate-fade-in">
                        <i class="fas fa-chart-bar"></i>
                        <p>У данного риелтора нет активных сделок</p>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    :root {
        --primary-color: #8b5cf6;
        --primary-hover: #7c3aed;
        --primary-bg: #f5f3ff;
        --bg-color: #f8fafc;
        --surface-color: #ffffff;
        --border-color: rgba(139, 92, 246, 0.15);
        --text-main: #1e293b;
        --text-dim: #64748b;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
        --shadow: 0 4px 6px rgba(0,0,0,0.07);
        --shadow-lg: 0 10px 30px rgba(139, 92, 246, 0.15);
    }

    .reports-dashboard {
        padding: 120px 30px 30px 30px;
        background: var(--bg-color);
        min-height: 100vh;
        color: var(--text-main);
        font-family: 'Inter', system-ui, sans-serif;
    }

    .dashboard-header { display: flex; align-items: center; gap: 20px; }
    .header-text h1 { font-size: 1.8rem; font-weight: 700; margin: 0; color: var(--text-main); }
    .header-text h1 .text-primary { background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .header-text p { color: var(--text-dim); margin: 4px 0 0; font-size: 0.95rem; }

    /* Анимации */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    @@keyframes modalSlideUp {
        from { opacity: 0; transform: translateY(40px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    
    @@keyframes rowSlideIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
    
    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@keyframes hoverPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.02); }
        100% { transform: scale(1); }
    }

    .fade-in-up {
        opacity: 0;
        animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .animate-fade-in { animation: fadeIn 0.3s ease forwards; }
    .animate-modal-in { animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .animate-row-in { animation: rowSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .animate-slide-down { animation: slideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .animate-hover:hover { animation: hoverPulse 0.3s ease; }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-500 { animation-delay: 0.5s; }
    .delay-600 { animation-delay: 0.6s; }
    .delay-700 { animation-delay: 0.7s; }

    /* Stats Cards */
    .stat-card-v2 {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        padding: 25px;
        display: flex; align-items: center; gap: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: var(--shadow);
        cursor: pointer;
    }
    .stat-card-v2:hover { 
        border-color: var(--primary-color); 
        transform: translateY(-5px); 
        box-shadow: var(--shadow-lg);
    }
    
    .card-icon-box {
        width: 55px;
        height: 55px;
        background: var(--primary-bg);
        border-radius: 15px;
        display: flex; align-items: center; justify-content: center;
        color: var(--primary-color); font-size: 1.4rem;
        transition: all 0.3s;
    }
    .stat-card-v2:hover .card-icon-box {
        background: var(--primary-color);
        color: white;
        transform: scale(1.1);
    }
    .card-icon-box.primary-icon { background: var(--primary-bg); color: var(--primary-color); }
    
    .v-number { display: block; font-size: 1.6rem; font-weight: 800; color: var(--text-main); }
    .v-label { color: var(--text-dim); font-size: 0.85rem; font-weight: 500; }

    /* Charts */
    .chart-glass-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        padding: 25px;
        height: 100%;
        box-shadow: var(--shadow);
        transition: all 0.3s;
    }
    .chart-glass-card:hover { border-color: var(--primary-color); box-shadow: var(--shadow-lg); }
    .chart-header { font-weight: 700; margin-bottom: 20px; font-size: 1.1rem; color: var(--text-main); display: flex; align-items: center; gap: 8px; }
    .chart-header i { color: var(--primary-color); }
    .canvas-container { position: relative; height: 300px; }

    /* Top Performers */
    .top-performers-section {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 24px;
        padding: 28px;
        box-shadow: var(--shadow);
        transition: all 0.3s;
    }
    .top-performers-section:hover { border-color: var(--primary-color); }
    
    .section-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 24px; color: var(--text-main); display: flex; align-items: center; gap: 10px; }
    .section-title i { color: var(--primary-color); }
    
    .performers-list { display: flex; flex-direction: column; gap: 12px; }
    
    .performer-horizontal-item {
        display: flex; align-items: center; gap: 20px;
        padding: 18px 24px;
        background: var(--bg-color);
        border-radius: 16px;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        border: 2px solid transparent;
    }
    .performer-horizontal-item:hover {
        background: var(--surface-color);
        border-color: var(--primary-color);
        transform: translateX(8px);
        box-shadow: var(--shadow);
    }
    
    .rank-badge { 
        width: 36px; height: 36px; 
        background: var(--primary-bg); 
        color: var(--primary-color); 
        border-radius: 10px; 
        display: flex; align-items: center; justify-content: center; 
        font-weight: 800; font-size: 0.9rem;
    }
    .p-avatar { 
        width: 48px; height: 48px;
        background: linear-gradient(135deg, var(--primary-color), var(--primary-hover)); 
        color: white; 
        border-radius: 50%; 
        display: flex; align-items: center; justify-content: center; 
        font-weight: 800; font-size: 1.3rem;
    }
    .p-details { flex-grow: 1; display: flex; flex-direction: column; }
    .p-name { font-weight: 700; font-size: 1rem; color: var(--text-main); }
    .p-sub { color: var(--text-dim); font-size: 0.85rem; }
    .p-revenue { text-align: right; }
    .p-amount { display: block; color: var(--primary-color); font-weight: 800; font-size: 1.1rem; }

    /* Loader */
    .loader-container { display: flex; justify-content: center; padding: 100px; }
    .premium-spinner { 
        width: 50px; height: 50px;
        border: 3px solid var(--primary-bg); 
        border-top-color: var(--primary-color); 
        border-radius: 50%; 
        animation: spin 1s infinite linear;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Utilities */
    .text-primary { color: var(--primary-color) !important; }
    .text-dim { color: var(--text-dim) !important; }
    .text-uppercase { text-transform: uppercase; letter-spacing: 1px; font-size: 0.75rem; font-weight: 600; }
    .fw-bold { font-weight: 700 !important; }
    .text-end { text-align: right !important; }
    .text-truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .d-none { display: none !important; }
    .mb-4 { margin-bottom: 1.5rem !important; }
    .me-1 { margin-right: 0.25rem !important; }
    .me-2 { margin-right: 0.5rem !important; }

    /* Modal Styles */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        padding: 20px;
    }

    .modal-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 28px;
        width: 100%;
        max-width: 1100px;
        max-height: 85vh;
        overflow: hidden;
        box-shadow: 0 25px 80px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
    }

    .modal-card-large { max-width: 1200px; }

    .modal-header {
        padding: 25px 35px;
        background: var(--primary-bg);
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h3 {
        font-weight: 700;
        font-size: 1.3rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text-main);
    }

    .modal-header h3 i { color: var(--primary-color); }

    .modal-subtitle {
        font-size: 0.75rem;
        color: var(--text-dim);
        font-weight: 600;
        margin-bottom: 4px;
        display: block;
    }

    .close-btn {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: none;
        background: var(--surface-color);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.3s;
        display: flex; align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }
    .close-btn:hover {
        background: #ef4444;
        color: white;
        transform: rotate(90deg);
    }

    .modal-body {
        padding: 30px;
        overflow-y: auto;
        color: var(--text-main);
    }

    .table-responsive { overflow-x: auto; }

    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

    .premium-table thead th {
        padding: 15px 20px;
        color: var(--text-dim);
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        border: none;
        text-align: left;
    }

    .premium-table tbody tr {
        background: var(--bg-color);
        transition: all 0.2s;
    }

    .premium-table tbody tr:hover {
        background: var(--primary-bg);
        transform: translateX(4px);
    }

    .premium-table td {
        padding: 18px 20px;
        border: none;
        vertical-align: middle;
        color: var(--text-main);
    }

    .premium-table td:first-child { border-radius: 12px 0 0 12px; }
    .premium-table td:last-child { border-radius: 0 12px 12px 0; }

    .status-badge {
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-block;
    }
