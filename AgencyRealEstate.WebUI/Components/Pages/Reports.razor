@code {
    private ReportData? report;
    private bool showObjectsModal = false;
    private string modalTitle = "";
    private List<PropertyItem>? modalObjects;
    private bool showRealtorModal = false;
    private string currentRealtorName = "";
    private List<RealtorDealInfo>? realtorDeals;

    // Флаг для однократной отрисовки графиков
    private bool chartsRendered = false;

    // Переменные для редактирования
    private PropertyItem? editingProperty;
    private EditPropertyModel editModel = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.Delay(500);
            report = await Http.GetFromJsonAsync<ReportData>("reports");
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Проверяем, что report не null, и мы ещё не отрисовывали графики
        if (report != null && !chartsRendered)  
        {
            chartsRendered = true; // Сразу ставим флаг, чтобы не дублировать логику
            await Task.Delay(100);
            
            var labels = report.MonthlyRevenue.Select(x => x.Period).ToArray();
            var revenueData = report.MonthlyRevenue.Select(x => (double)x.TotalAmount).ToArray();
            var transactionData = report.MonthlyRevenue.Select(x => x.Count).ToArray();
            
            var canvasExists = await JS.InvokeAsync<bool>("eval", "document.getElementById('revenueChart') !== null");
            if (canvasExists)
            {
                await JS.InvokeVoidAsync("setupDoubleCharts", labels, revenueData, transactionData);
            }
        }
    }

    private void ShowObjectsModal(string? statusFilter)
    {
        if (report == null || report.Properties?.List == null) return;

        modalObjects = statusFilter switch
        {
            "Available" => report.Properties.List.Where(p => p.StatusName == "Available").ToList(),
            "Sold" => report.Properties.List.Where(p => p.StatusName == "Sold" || p.StatusName == "Rented").ToList(),
            _ => report.Properties.List.ToList()
        };

        modalTitle = statusFilter switch
        {
            "Available" => "Доступные объекты",
            "Sold" => "Проданные/Сданные объекты",
            _ => "Все объекты"
        };

        editingProperty = null;
        showObjectsModal = true;
    }

    private async Task ShowRealtorDeals(string realtorName)
    {
        currentRealtorName = realtorName;
        realtorDeals = null;
        showRealtorModal = true;
        StateHasChanged();
        try
        {
            realtorDeals = await Http.GetFromJsonAsync<List<RealtorDealInfo>>($"reports/realtor/{Uri.EscapeDataString(realtorName)}");
            StateHasChanged();
        }
        catch
        {
            realtorDeals = new();
            StateHasChanged();
        }
    }

    private void CloseModals()
    {
        showObjectsModal = false;
        showRealtorModal = false;
        editingProperty = null;
    }

    private void StartEdit(PropertyItem item)
    {
        editingProperty = item;
        editModel = new EditPropertyModel
        {
            Title = item.Title,
            Address = item.Address,
            Price = item.Price,
            Rooms = item.Rooms,
            Bathrooms = item.Bathrooms,
            TotalArea = item.TotalArea,
            LivingArea = null,
            Floor = null,
            Description = null
        };
    }

    private void CancelEdit() => editingProperty = null;

    private async Task SaveEdit()
    {
        if (editingProperty == null) return;

        try
        {
            var response = await Http.PutAsJsonAsync($"properties/{editingProperty.PropertyId}", editModel);

            if (response.IsSuccessStatusCode)
            {
                var updated = await Http.GetFromJsonAsync<PropertyItem>($"properties/{editingProperty.PropertyId}");

                if (updated != null && modalObjects != null)
                {
                    var index = modalObjects.FindIndex(o => o.PropertyId == editingProperty.PropertyId);
                    if (index >= 0) modalObjects[index] = updated;
                }
                CancelEdit();
            }
        }
        catch { }
    }

    private async Task DeleteProperty(PropertyItem item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить объект #{item.PropertyId}?");

        if (!confirmed) return;
        try
        {
            var response = await Http.DeleteAsync($"properties/{item.PropertyId}");

            if (response.IsSuccessStatusCode)
            {
                modalObjects?.RemoveAll(o => o.PropertyId == item.PropertyId);
                report = await Http.GetFromJsonAsync<ReportData>("reports");
                StateHasChanged();
            }
        }
        catch { }
    }

    private string activeSortColumn = "";
    private bool isAscending = true;

    private void SortList<T>(List<T>? list, string column, Func<T, object?> selector)
    {
        if (list == null || !list.Any()) return;

        if (activeSortColumn == column) isAscending = !isAscending;
        else { activeSortColumn = column; isAscending = true; }
        var sorted = isAscending ? list.OrderBy(selector).ToList() : list.OrderByDescending(selector).ToList();

        if (typeof(T) == typeof(PropertyItem) && modalObjects != null) modalObjects = sorted.Cast<PropertyItem>().ToList();
        else if (typeof(T) == typeof(RealtorDealInfo) && realtorDeals != null) realtorDeals = sorted.Cast<RealtorDealInfo>().ToList();
        StateHasChanged();
    }

    private string GetSortIcon(string column)
    {
        if (activeSortColumn != column) return "fas fa-sort ms-1 opacity-50";
        return isAscending ? "fas fa-sort-up ms-1 text-primary" : "fas fa-sort-down ms-1 text-primary";
    }
    
    // === МОДЕЛИ ===
    public class ReportData
    {
        public PropertiesReport Properties { get; set; } = new();
        public List<MonthlyRevenue> MonthlyRevenue { get; set; } = new();
        public RealtorsReport Realtors { get; set; } = new();
    }
    
