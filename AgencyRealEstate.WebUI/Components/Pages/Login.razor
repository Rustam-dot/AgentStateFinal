@page "/login"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using AgencyRealEstate.WebUI.Services
@using AgencyRealEstate.WebUI.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject TokenStorage TokenStorage
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@attribute [AllowAnonymous]

<div class="page-background-clean">
    <div class="particles-container">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <div class="container-form-clean">
        
        <div class="auth-logo stagger-1" @onclick='() => Navigation.NavigateTo("/")'>
            <div class="logo-icon">
                <i class="fas fa-home"></i>
            </div>
            <div class="logo-text">РеалтиПро</div>
        </div>

        <div class="header-subtitle stagger-2">
            <p>Добро пожаловать в систему</p>
        </div>

        <div class="form-clean-card stagger-3">
            
            <div class="toggle-wrapper stagger-4">
                <div class="toggle-bg @(!isLogin ? "right" : "")"></div>
                <button type="button" class="toggle-btn @(isLogin ? "active" : "")" @onclick="() => isLogin = true">Вход</button>
                <button type="button" class="toggle-btn @(!isLogin ? "active" : "")" @onclick="() => isLogin = false">Регистрация</button>
            </div>

            <div class="form-content">
                @if (isLogin)
                {
                    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />
                        
                        <div class="form-group stagger-5">
                            <InputText @bind-Value="loginModel.Login" placeholder="Логин" class="input-clean" />
                            <ValidationMessage For="@(() => loginModel.Login)" class="validation-msg" />
                        </div>

                        <div class="form-group stagger-6">
                            <InputText @bind-Value="loginModel.Password" type="password" placeholder="Пароль" class="input-clean" />
                            <ValidationMessage For="@(() => loginModel.Password)" class="validation-msg" />
                        </div>
                        
                        <div class="bottom-row login-bottom stagger-7">
                            <button type="submit" class="btn-submit-clean">
                                Войти <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                            <a href="#" @onclick:preventDefault class="forgot-link">Забыли пароль?</a>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert-msg error-msg stagger-8"><i class="fas fa-exclamation-circle"></i> @errorMessage</div>
                        }
                    </EditForm>
                }
                else
                {
                    <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                        <DataAnnotationsValidator />
                        
                        <div class="form-group stagger-5">
                            <InputText @bind-Value="registerModel.FullName" placeholder="Полное имя" class="input-clean" />
                            <ValidationMessage For="@(() => registerModel.FullName)" class="validation-msg" />
                        </div>

                        <div class="form-group stagger-6">
                            <InputText @bind-Value="registerModel.Login" placeholder="Логин" class="input-clean" />
                            <ValidationMessage For="@(() => registerModel.Login)" class="validation-msg" />
                        </div>

                        <div class="form-group stagger-7">
                            <InputText @bind-Value="registerModel.Email" placeholder="Электронная почта" class="input-clean" />
                            <ValidationMessage For="@(() => registerModel.Email)" class="validation-msg" />
                        </div>

                        <div class="form-group stagger-8">
                            <InputText @bind-Value="registerModel.Phone" placeholder="Телефон" class="input-clean" />
                            <ValidationMessage For="@(() => registerModel.Phone)" class="validation-msg" />
                        </div>

                        <div class="form-group stagger-9">
                            <InputText @bind-Value="registerModel.Password" type="password" placeholder="Пароль" class="input-clean" />
                            <ValidationMessage For="@(() => registerModel.Password)" class="validation-msg" />
                        </div>
                        
                        <div class="form-group stagger-10 terms-group">
                            <label class="custom-checkbox">
                                <InputCheckbox @bind-Value="registerModel.AcceptTerms" />
                                <span class="checkmark"></span>
                                <span class="terms-text">
                                    Я принимаю <a href="#" class="purple-link">Условия использования</a> и <a href="#" class="purple-link">Политику конфиденциальности</a>
                                </span>
                            </label>
                            <ValidationMessage For="@(() => registerModel.AcceptTerms)" class="validation-msg" />
                        </div>
                        
                        <div class="bottom-row register-bottom stagger-11">
                            <button type="submit" class="btn-submit-clean w-100">
                                Зарегистрироваться <i class="fas fa-user-plus ms-2"></i>
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert-msg success-msg stagger-12"><i class="fas fa-check-circle"></i> @successMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert-msg error-msg stagger-12"><i class="fas fa-exclamation-circle"></i> @errorMessage</div>
                        }
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary-purple: #8b5cf6;
        --primary-purple-hover: #7c3aed;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-page: #fdf2f8; /* Легкий розоватый оттенок для фона */
        --bg-card: #ffffff;
        --border-color: #e5e7eb;
        --input-focus-ring: rgba(139, 92, 246, 0.15);
    }

    .page-background-clean {
        /* Обновлен градиент фона как на изображении */
        background: radial-gradient(circle at center, #ffffff 0%, #fef5fb 40%, #f4e8ff 100%);
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Inter', 'Roboto', sans-serif;
        padding: 20px;
        position: relative;
        overflow: hidden;
    }

    /* === Анимация фона с кружками === */
    .particles-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        bottom: -50px;
        background: rgba(216, 150, 255, 0.5); /* Фиолетово-розовый цвет кружков */
        border-radius: 50%;
        filter: blur(2px);
        animation: floatUp 15s infinite linear;
    }

    @@keyframes floatUp {
        0% { transform: translateY(0) scale(0.8); opacity: 0; }
        10% { opacity: 0.7; }
        50% { transform: translateY(-50vh) scale(1.2); opacity: 0.5; }
        90% { opacity: 0; }
        100% { transform: translateY(-100vh) scale(1); opacity: 0; }
    }

    /* Случайные параметры для каждого кружка */
    .particle:nth-child(1) { left: 10%; width: 12px; height: 12px; animation-duration: 12s; animation-delay: 0s; }
    .particle:nth-child(2) { left: 25%; width: 18px; height: 18px; animation-duration: 18s; animation-delay: 2s; }
    .particle:nth-child(3) { left: 45%; width: 8px; height: 8px; animation-duration: 14s; animation-delay: 4s; }
    .particle:nth-child(4) { left: 65%; width: 22px; height: 22px; animation-duration: 20s; animation-delay: 1s; }
    .particle:nth-child(5) { left: 85%; width: 15px; height: 15px; animation-duration: 16s; animation-delay: 5s; }
    .particle:nth-child(6) { left: 15%; width: 25px; height: 25px; animation-duration: 22s; animation-delay: 7s; }
    .particle:nth-child(7) { left: 55%; width: 10px; height: 10px; animation-duration: 15s; animation-delay: 3s; }
    .particle:nth-child(8) { left: 95%; width: 14px; height: 14px; animation-duration: 19s; animation-delay: 8s; }
    .particle:nth-child(9) { left: 35%; width: 20px; height: 20px; animation-duration: 17s; animation-delay: 6s; }
    .particle:nth-child(10) { left: 75%; width: 12px; height: 12px; animation-duration: 21s; animation-delay: 9s; }
    .particle:nth-child(11) { left: 5%; width: 16px; height: 16px; animation-duration: 13s; animation-delay: 11s; }
    .particle:nth-child(12) { left: 80%; width: 9px; height: 9px; animation-duration: 24s; animation-delay: 10s; }


    .container-form-clean {
        width: 100%;
        max-width: 440px;
        z-index: 10;
        perspective: 1000px;
    }

    /* Анимация каскадного появления сверху вниз */
    @@keyframes cascadeDown {
        0% { opacity: 0; transform: translateY(-30px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    .stagger-1 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.1s; }
    .stagger-2 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.2s; }
    .stagger-3 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.3s; }
    .stagger-4 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.4s; }
    .stagger-5 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.5s; }
    .stagger-6 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.6s; }
    .stagger-7 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.7s; }
    .stagger-8 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.8s; }
    .stagger-9 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 0.9s; }
    .stagger-10 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 1.0s; }
    .stagger-11 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 1.1s; }
    .stagger-12 { opacity: 0; animation: cascadeDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; animation-delay: 1.2s; }

    /* Логотип с эффектом наведения */
    .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        cursor: pointer;
        margin-bottom: 10px;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .auth-logo:hover {
        transform: scale(1.15);
    }

    .logo-icon {
        width: 44px;
        height: 44px;
        border: 2px solid var(--primary-purple);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-purple);
        font-size: 1.3rem;
    }

    .logo-text {
        color: var(--primary-purple);
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .header-subtitle {
        text-align: center;
        margin-bottom: 30px;
    }

    .header-subtitle p {
        color: var(--text-muted);
        font-size: 1rem;
        margin: 0;
        font-weight: 500;
    }

    /* Карточка */
    .form-clean-card {
        background: var(--bg-card);
        padding: 40px;
        border-radius: 24px;
        border: 1px solid var(--border-color);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
    }

    /* Переключатель */
    .toggle-wrapper {
        display: flex;
        position: relative;
        background: #f3f4f6;
        border-radius: 12px;
        margin: 0 auto 30px auto;
        padding: 5px;
    }

    .toggle-btn {
        flex: 1;
        padding: 12px 0;
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        z-index: 2;
        transition: color 0.3s ease;
        text-align: center;
    }

    .toggle-btn.active {
        color: #ffffff;
    }

    .toggle-bg {
        position: absolute;
        top: 5px;
        left: 5px;
        width: calc(50% - 5px);
        height: calc(100% - 10px);
        background: var(--primary-purple);
        border-radius: 8px;
        transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        z-index: 1;
        box-shadow: 0 4px 10px rgba(139, 92, 246, 0.2);
    }

    .toggle-bg.right {
        transform: translateX(100%);
    }

    .form-group {
        margin-bottom: 18px;
    }

    /* Поля ввода */
    .input-clean {
        background: #ffffff !important;
        width: 100%;
        box-sizing: border-box;
        padding: 14px 20px;
        border: 1px solid var(--border-color) !important;
        border-radius: 12px !important;
        color: var(--text-main) !important;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .input-clean::placeholder {
        color: #9ca3af;
    }

    .input-clean:focus {
        outline: none;
        border-color: var(--primary-purple) !important;
        box-shadow: 0 0 0 4px var(--input-focus-ring);
    }

    .validation-msg {
        color: #ef4444;
        font-size: 0.8rem;
        margin-top: 6px;
        display: block;
        margin-left: 5px;
    }

    /* === Стили для Чекбокса Условий === */
    .terms-group {
        display: flex;
        flex-direction: column;
        margin-top: 10px;
        margin-bottom: 25px;
    }

    .custom-checkbox {
        display: flex;
        align-items: flex-start;
        position: relative;
        cursor: pointer;
        user-select: none;
        gap: 12px;
    }

    .custom-checkbox input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        height: 0;
        width: 0;
    }

    .checkmark {
        height: 22px;
        width: 22px;
        background-color: #3f3f46; /* Темно-серый квадрат как на фото */
        border-radius: 4px;
        display: inline-block;
        position: relative;
        flex-shrink: 0;
        margin-top: 2px;
        transition: background-color 0.2s ease;
    }

    .custom-checkbox input:checked ~ .checkmark {
        background-color: var(--primary-purple); /* Закрашивается в фиолетовый при клике */
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
    }

    .custom-checkbox input:checked ~ .checkmark:after {
        display: block;
    }

    .custom-checkbox .checkmark:after {
        left: 8px;
        top: 4px;
        width: 5px;
        height: 10px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }

    .terms-text {
        font-size: 0.95rem;
        color: var(--text-main);
        line-height: 1.5;
        font-weight: 400;
    }

    .purple-link {
        color: var(--primary-purple);
        text-decoration: none;
        transition: color 0.2s;
    }

    .purple-link:hover {
        color: var(--primary-purple-hover);
        text-decoration: underline;
    }

    .bottom-row {
        display: flex;
        align-items: center;
        margin-top: 25px;
    }

    .login-bottom {
        justify-content: space-between;
    }

    /* Кнопки */
    .btn-submit-clean {
        background: var(--primary-purple) !important;
        color: #ffffff !important;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-submit-clean:hover {
        background: var(--primary-purple-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(139, 92, 246, 0.3);
    }

    .w-100 {
        width: 100%;
    }

    .forgot-link {
        text-decoration: none;
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .forgot-link:hover {
        color: var(--primary-purple);
    }

    /* Оповещения */
    .alert-msg {
        margin-top: 20px;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .error-msg {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fee2e2;
    }

    .success-msg {
        background: #f0fdf4;
        color: #22c55e;
        border: 1px solid #dcfce3;
    }

    @@media (max-width: 576px) {
        .form-clean-card {
            padding: 30px 20px;
        }
    }
</style>

@code {
    private bool isLogin = true;
    private LoginRequest loginModel = new();
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private string? successMessage;

    public class LoginRequest
    {
        [Required(ErrorMessage = "Введите логин")]
        public string Login { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        public string Password { get; set; } = "";
    }

    public class RegisterRequest
    {
        [Required(ErrorMessage = "Введите полное имя")]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Введите логин")]
        public string Login { get; set; } = "";

        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Некорректный email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Введите телефон")]
        [Phone(ErrorMessage = "Некорректный телефон")]
        public string Phone { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        public string Password { get; set; } = "";

        // Валидация на то, что галочка должна быть отмечена (true)
        [Range(typeof(bool), "true", "true", ErrorMessage = "Необходимо принять условия использования и политику конфиденциальности")]
        public bool AcceptTerms { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (result != null)
                {
                    await JS.InvokeVoidAsync("eval", $"document.cookie = 'authToken={result.Token}; path=/; secure; samesite=strict; max-age=86400'");
                    TokenStorage.Token = result.Token;
                    ((TokenAuthenticationStateProvider)AuthStateProvider).NotifyAuthStateChanged();
                    Navigation.NavigateTo("/", forceLoad: false); 
                }
                else
                {
                    errorMessage = "Ошибка чтения ответа.";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = errorContent.Contains("error") ? errorContent : "Неверный логин или пароль";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка соединения: {ex.Message}";
        }
    }

    private async Task HandleRegister()
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("auth/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Регистрация прошла успешно! Теперь вы можете войти.";
                isLogin = true;
                registerModel = new RegisterRequest();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = errorContent.Contains("error") ? errorContent : "Ошибка регистрации";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка соединения: {ex.Message}";
        }
    }

    public class LoginResponse 
    {
        public string Token { get; set; } = string.Empty;
    }
}