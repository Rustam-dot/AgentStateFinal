@code {
    private bool isLogin = true;
    private bool isLoading = false;
    private LoginRequest loginModel = new();
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private string? successMessage;

    public class LoginRequest
    {
        [Required(ErrorMessage = "Введите логин")]
        public string Login { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        public string Password { get; set; } = "";
    }

    public class RegisterRequest
    {
        [Required(ErrorMessage = "Введите полное имя")]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "Введите логин")]
        public string Login { get; set; } = "";

        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Некорректный email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Введите телефон")]
        [Phone(ErrorMessage = "Некорректный телефон")]
        public string Phone { get; set; } = "";

        [Required(ErrorMessage = "Введите пароль")]
        public string Password { get; set; } = "";

        [Range(typeof(bool), "true", "true", ErrorMessage = "Необходимо принять условия использования")]
        public bool AcceptTerms { get; set; }
    }

    private string GetParticleStyle(int index)
    {
        var random = new Random(index);
        var left = random.Next(5, 95);
        var size = random.Next(8, 30);
        var duration = random.Next(15, 30);
        var delay = random.Next(0, 20);
        
        return $"left: {left}%; width: {size}px; height: {size}px; animation-duration: {duration}s; animation-delay: {delay}s;";
    }

    private void SwitchMode(bool login)
    {
        isLogin = login;
        errorMessage = null;
        successMessage = null;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (result != null)
                {
                    await JS.InvokeVoidAsync("eval", $"document.cookie = 'authToken={result.Token}; path=/; secure; samesite=strict; max-age=86400'");
                    TokenStorage.Token = result.Token;
                    ((TokenAuthenticationStateProvider)AuthStateProvider).NotifyAuthStateChanged();
                    Navigation.NavigateTo("/", forceLoad: false); 
                }
                else
                {
                    errorMessage = "Ошибка чтения ответа.";
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = errorContent.Contains("error") ? errorContent : "Неверный логин или пароль";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка соединения: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("auth/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Регистрация прошла успешно! Теперь вы можете войти.";
                isLogin = true;
                registerModel = new RegisterRequest();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = errorContent.Contains("error") ? errorContent : "Ошибка регистрации";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка соединения: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginResponse 
    {
        public string Token { get; set; } = string.Empty;
    }
}