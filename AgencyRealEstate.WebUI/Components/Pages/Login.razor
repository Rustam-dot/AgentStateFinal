@page "/login"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.ComponentModel.DataAnnotations
@using AgencyRealEstate.WebUI.Services
@using AgencyRealEstate.WebUI.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject TokenStorage TokenStorage
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@attribute [AllowAnonymous]

<div class="page-background">
    <!-- Живой градиентный фон -->
    <div class="gradient-bg"></div>
    
    <!-- Плавающие частицы -->
    <div class="particles-container">
        @for (int i = 0; i < 15; i++)
        {
            <div class="particle" style="@GetParticleStyle(i)"></div>
        }
    </div>

    <!-- Стеклянная карточка -->
    <div class="glass-container">
        
        <!-- Логотип с анимацией -->
        <div class="auth-logo" @onclick='() => Navigation.NavigateTo("/")'>
            <div class="logo-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
            </div>
            <div class="logo-text">РеалтиПро</div>
        </div>

        <div class="header-subtitle">
            <p>Добро пожаловать в систему</p>
            <span class="subtitle-line"></span>
        </div>

        <div class="form-card">
            
            <!-- Переключатель с анимацией скольжения -->
            <div class="toggle-wrapper">
                <div class="toggle-slider" style="@(isLogin ? "transform: translateX(0)" : "transform: translateX(100%)")"></div>
                <button type="button" class="toggle-btn @(isLogin ? "active" : "")" @onclick="() => SwitchMode(true)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <polyline points="10 17 15 12 10 7"></polyline>
                        <line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                    Вход
                </button>
                <button type="button" class="toggle-btn @(!isLogin ? "active" : "")" @onclick="() => SwitchMode(false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <line x1="20" y1="8" x2="20" y2="14"></line>
                        <line x1="23" y1="11" x2="17" y2="11"></line>
                    </svg>
                    Регистрация
                </button>
            </div>

            <div class="form-content">
                @if (isLogin)
                {
                    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm" class="animate-in">
                        <DataAnnotationsValidator />
                        
                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <InputText @bind-Value="loginModel.Login" placeholder="Логин" class="input-field" />
                            <ValidationMessage For="@(() => loginModel.Login)" class="validation-msg" />
                        </div>

                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <InputText @bind-Value="loginModel.Password" type="password" placeholder="Пароль" class="input-field" />
                            <ValidationMessage For="@(() => loginModel.Password)" class="validation-msg" />
                        </div>
                        
                        <div class="options-row">
                            <label class="remember-me">
                                <input type="checkbox" />
                                <span class="checkmark"></span>
                                <span>Запомнить меня</span>
                            </label>
                            <a href="#" @onclick:preventDefault class="forgot-link">Забыли пароль?</a>
                        </div>
                        
                        <button type="submit" class="btn-submit" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner"></span>
                                <span>Вход...</span>
                            }
                            else
                            {
                                <span>Войти</span>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            }
                        </button>
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert error animate-shake">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="12"></line>
                                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                </svg>
                                @errorMessage
                            </div>
                        }
                    </EditForm>
                }
                else
                {
                    <EditForm Model="registerModel" OnValidSubmit="HandleRegister" FormName="registerForm" class="animate-in">
                        <DataAnnotationsValidator />
                        
                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <InputText @bind-Value="registerModel.FullName" placeholder="Полное имя" class="input-field" />
                            <ValidationMessage For="@(() => registerModel.FullName)" class="validation-msg" />
                        </div>

                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <InputText @bind-Value="registerModel.Login" placeholder="Логин" class="input-field" />
                            <ValidationMessage For="@(() => registerModel.Login)" class="validation-msg" />
                        </div>

                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                    <polyline points="22,6 12,13 2,6"></polyline>
                                </svg>
                            </div>
                            <InputText @bind-Value="registerModel.Email" placeholder="Электронная почта" class="input-field" />
                            <ValidationMessage For="@(() => registerModel.Email)" class="validation-msg" />
                        </div>

                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                                </svg>
                            </div>
                            <InputText @bind-Value="registerModel.Phone" placeholder="Телефон" class="input-field" />
                            <ValidationMessage For="@(() => registerModel.Phone)" class="validation-msg" />
                        </div>

                        <div class="input-group">
                            <div class="input-icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                            </div>
                            <InputText @bind-Value="registerModel.Password" type="password" placeholder="Пароль" class="input-field" />
                            <ValidationMessage For="@(() => registerModel.Password)" class="validation-msg" />
                        </div>
                        
                        <div class="terms-group">
                            <label class="custom-checkbox">
                                <InputCheckbox @bind-Value="registerModel.AcceptTerms" />
                                <span class="checkmark"></span>
                                <span class="terms-text">
                                    Я принимаю <a href="#" class="link-purple">Условия использования</a> и <a href="#" class="link-purple">Политику конфиденциальности</a>
                                </span>
                            </label>
                            <ValidationMessage For="@(() => registerModel.AcceptTerms)" class="validation-msg" />
                        </div>
                        
                        <button type="submit" class="btn-submit w-100" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner"></span>
                                <span>Регистрация...</span>
                            }
                            else
                            {
                                <span>Зарегистрироваться</span>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            }
                        </button>

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert success animate-in">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                </svg>
                                @successMessage
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert error animate-shake">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="12"></line>
                                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                </svg>
                                @errorMessage
                            </div>
                        }
                    </EditForm>
                }
            </div>
        </div>
        
        <!-- Декоративная подпись -->
        <div class="footer-text">
            <span>© 2026 РеалтиПро</span>
            <span class="dot">•</span>
            <span>Защищено SSL</span>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #7c3aed;
        --primary-hover: #6d28d9;
        --primary-light: rgba(124, 58, 237, 0.1);
        --primary-glow: rgba(124, 58, 237, 0.3);
        --text-main: #1e1b4b;
        --text-secondary: #64748b;
        --text-muted: #94a3b8;
        --bg-gradient-1: #f5f3ff;
        --bg-gradient-2: #ede9fe;
        --bg-gradient-3: #ddd6fe;
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.5);
        --glass-shadow: 0 8px 32px rgba(124, 58, 237, 0.1);
        --error: #ef4444;
        --success: #10b981;
    }

    /* === Фон === */
    .page-background {
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        padding: 20px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, var(--bg-gradient-1) 0%, var(--bg-gradient-2) 50%, var(--bg-gradient-3) 100%);
    }

    .gradient-bg {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 30% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
                    radial-gradient(circle at 70% 80%, rgba(168, 85, 247, 0.1) 0%, transparent 50%);
        animation: gradientMove 20s ease-in-out infinite;
    }

    @@keyframes gradientMove {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(2%, 2%) rotate(1deg); }
        66% { transform: translate(-1%, 1%) rotate(-1deg); }
    }

    /* === Частицы === */
    .particles-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.4), rgba(168, 85, 247, 0.2));
        border-radius: 50%;
        filter: blur(1px);
        animation: floatParticle linear infinite;
    }

    @@keyframes floatParticle {
        0% { transform: translateY(100vh) rotate(0deg) scale(0.5); opacity: 0; }
        10% { opacity: 0.8; }
        90% { opacity: 0.8; }
        100% { transform: translateY(-100vh) rotate(720deg) scale(1.5); opacity: 0; }
    }

    /* === Стеклянный контейнер === */
    .glass-container {
        width: 100%;
        max-width: 420px;
        z-index: 10;
        position: relative;
    }

    /* === Логотип === */
    .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        cursor: pointer;
        margin-bottom: 16px;
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        animation: fadeInDown 0.8s ease-out;
    }

    .auth-logo:hover {
        transform: scale(1.08) translateY(-2px);
    }

    .logo-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), #a78bfa);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
        transition: box-shadow 0.3s ease;
    }

    .auth-logo:hover .logo-icon {
        box-shadow: 0 6px 25px rgba(124, 58, 237, 0.4);
    }

    .logo-icon svg {
        width: 24px;
        height: 24px;
    }

    .logo-text {
        color: var(--text-main);
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
        background: linear-gradient(135deg, var(--primary), #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* === Подзаголовок === */
    .header-subtitle {
        text-align: center;
        margin-bottom: 32px;
        animation: fadeInDown 0.8s ease-out 0.1s both;
    }

    .header-subtitle p {
        color: var(--text-secondary);
        font-size: 1rem;
        margin: 0 0 12px 0;
        font-weight: 500;
    }

    .subtitle-line {
        display: block;
        width: 40px;
        height: 3px;
        background: linear-gradient(90deg, var(--primary), #a78bfa);
        border-radius: 2px;
        margin: 0 auto;
        animation: expandLine 1s ease-out 0.5s both;
    }

    @@keyframes expandLine {
        from { width: 0; opacity: 0; }
        to { width: 40px; opacity: 1; }
    }

    /* === Карточка === */
    .form-card {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        padding: 40px;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow), 0 0 0 1px rgba(255, 255, 255, 0.5) inset;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    /* === Переключатель === */
    .toggle-wrapper {
        display: flex;
        position: relative;
        background: rgba(243, 244, 246, 0.6);
        border-radius: 14px;
        margin-bottom: 28px;
        padding: 4px;
        border: 1px solid rgba(229, 231, 235, 0.5);
    }

    .toggle-slider {
        position: absolute;
        top: 4px;
        left: 4px;
        width: calc(50% - 4px);
        height: calc(100% - 8px);
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        border-radius: 10px;
        transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        z-index: 1;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.25);
    }

    .toggle-btn {
        flex: 1;
        padding: 12px 0;
        background: transparent;
        border: none;
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        z-index: 2;
        transition: color 0.3s ease;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        position: relative;
    }

    .toggle-btn.active {
        color: #ffffff;
    }

    .toggle-btn svg {
        transition: transform 0.3s ease;
    }

    .toggle-btn:hover svg {
        transform: scale(1.1);
    }

    /* === Поля ввода === */
    .input-group {
        margin-bottom: 16px;
        position: relative;
        animation: fadeInUp 0.6s ease-out both;
    }

    .input-group:nth-child(1) { animation-delay: 0.3s; }
    .input-group:nth-child(2) { animation-delay: 0.4s; }
    .input-group:nth-child(3) { animation-delay: 0.5s; }
    .input-group:nth-child(4) { animation-delay: 0.6s; }
    .input-group:nth-child(5) { animation-delay: 0.7s; }
    .input-group:nth-child(6) { animation-delay: 0.8s; }

    .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        z-index: 2;
        transition: color 0.3s ease;
        pointer-events: none;
    }

    .input-field {
        background: rgba(255, 255, 255, 0.8) !important;
        width: 100%;
        box-sizing: border-box;
        padding: 14px 16px 14px 48px;
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 12px !important;
        color: var(--text-main) !important;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .input-field::placeholder {
        color: #94a3b8;
    }

    .input-field:focus {
        outline: none;
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 4px var(--primary-light), 0 1px 3px rgba(0,0,0,0.05);
        background: #ffffff !important;
    }

    .input-field:focus + .input-icon,
    .input-group:focus-within .input-icon {
        color: var(--primary);
    }

    .validation-msg {
        color: var(--error);
        font-size: 0.8rem;
        margin-top: 6px;
        display: block;
        margin-left: 4px;
        animation: shake 0.5s ease-in-out;
    }

    /* === Опции === */
    .options-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 20px 0;
        font-size: 0.85rem;
    }

    .remember-me {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        user-select: none;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .remember-me input {
        display: none;
    }

    .remember-me .checkmark {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .remember-me input:checked + .checkmark {
        background: var(--primary);
        border-color: var(--primary);
    }

    .remember-me input:checked + .checkmark::after {
        content: '';
        width: 5px;
        height: 9px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
        margin-bottom: 2px;
    }

    .forgot-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        position: relative;
    }

    .forgot-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--primary);
        transition: width 0.3s ease;
    }

    .forgot-link:hover::after {
        width: 100%;
    }

    /* === Чекбокс условий === */
    .terms-group {
        margin: 20px 0;
    }

    .custom-checkbox {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        cursor: pointer;
        user-select: none;
    }

    .custom-checkbox input {
        display: none;
    }

    .custom-checkbox .checkmark {
        width: 22px;
        height: 22px;
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
        transition: all 0.2s ease;
    }

    .custom-checkbox input:checked + .checkmark {
        background: var(--primary);
        border-color: var(--primary);
        box-shadow: 0 2px 8px rgba(124, 58, 237, 0.3);
    }

    .custom-checkbox input:checked + .checkmark::after {
        content: '';
        width: 5px;
        height: 9px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
        margin-bottom: 2px;
    }

    .terms-text {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    .link-purple {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
        position: relative;
    }

    .link-purple:hover {
        color: var(--primary-hover);
    }

    .link-purple::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 0;
        height: 1.5px;
        background: var(--primary);
        transition: width 0.3s ease;
    }

    .link-purple:hover::after {
        width: 100%;
    }

    /* === Кнопка === */
    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, var(--primary), #8b5cf6) !important;
        color: #ffffff !important;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 8px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);
    }

    .btn-submit::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .btn-submit:hover::before {
        left: 100%;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
