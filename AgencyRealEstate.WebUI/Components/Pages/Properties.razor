@code {
    string? _searchQuery;
    string? SearchQuery 
    { 
        get => _searchQuery; 
        set { if (_searchQuery != value) { _searchQuery = value; ApplyFilters(); } } 
    }

    string? _filterType;
    string? FilterType 
    { 
        get => _filterType; 
        set { if (_filterType != value) { _filterType = value; ApplyFilters(); } } 
    }

    string _filterSort = "new";
    string FilterSort 
    { 
        get => _filterSort; 
        set { if (_filterSort != value) { _filterSort = value; ApplyFilters(); } } 
    }

    bool showFilters = false;
    string viewMode = "grid";
    PropertyDto? selectedProperty;

    // Photo rotation for cards
    Dictionary<int, int> cardPhotoIndexes = new();
    Dictionary<int, System.Threading.Timer> cardPhotoTimers = new();

    // Modal carousel
    List<string>? modalPhotoUrls;
    int modalCurrentPhotoIndex = 0;

    List<PropertyDto>? allProperties;
    List<PropertyDto>? filteredProperties;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allProperties = await Api.GetPropertiesAsync();
            ApplyFilters();
        }
        catch
        {
            filteredProperties = new();
        }
    }

    void ToggleFilters() => showFilters = !showFilters;

    void ApplyFilters()
    {
        if (allProperties == null)
        {
            filteredProperties = new();
            return;
        }

        var query = allProperties.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            query = query.Where(p => 
                (p.Title?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) == true) ||
                (p.Address?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) == true)
            );
        }

        if (!string.IsNullOrEmpty(FilterType))
            query = query.Where(p => p.PropertyTypeName == FilterType);

        query = FilterSort switch
        {
            "price_asc" => query.OrderBy(p => p.Price),
            "price_desc" => query.OrderByDescending(p => p.Price),
            _ => query
        };

        filteredProperties = query.ToList();
    }

    void ResetFilters()
    {
        SearchQuery = null;
        FilterType = null;
        FilterSort = "new";
        ApplyFilters();
    }

    // Card photo rotation
    void StartPhotoRotation(PropertyDto prop)
    {
        if (prop.PhotoUrls == null || prop.PhotoUrls.Count <= 1) return;
        StopPhotoRotation(prop);
        var timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                var current = cardPhotoIndexes.GetValueOrDefault(prop.PropertyID, 0);
                cardPhotoIndexes[prop.PropertyID] = (current + 1) % prop.PhotoUrls!.Count;
                StateHasChanged();
            });
        }, null, 1500, 1500);
        cardPhotoTimers[prop.PropertyID] = timer;
    }

    void StopPhotoRotation(PropertyDto prop)
    {
        if (cardPhotoTimers.TryGetValue(prop.PropertyID, out var timer))
        {
            timer.Dispose();
            cardPhotoTimers.Remove(prop.PropertyID);
        }
    }

    void OpenModal(PropertyDto prop)
    {
        selectedProperty = prop;
        modalPhotoUrls = prop.PhotoUrls?.ToList() ?? new();
        modalCurrentPhotoIndex = 0;
    }

    void CloseModal()
    {
        selectedProperty = null;
        modalPhotoUrls = null;
        modalCurrentPhotoIndex = 0;
    }

    void PrevModalPhoto()
    {
        if (modalPhotoUrls == null || modalPhotoUrls.Count <= 1) return;
        modalCurrentPhotoIndex = (modalCurrentPhotoIndex - 1 + modalPhotoUrls.Count) % modalPhotoUrls.Count;
        StateHasChanged();
    }

    void NextModalPhoto()
    {
        if (modalPhotoUrls == null || modalPhotoUrls.Count <= 1) return;
        modalCurrentPhotoIndex = (modalCurrentPhotoIndex + 1) % modalPhotoUrls.Count;
        StateHasChanged();
    }

    void GoToModalPhoto(int index)
    {
        modalCurrentPhotoIndex = index;
        StateHasChanged();
    }

    void GoToBooking(int id)
    {
        selectedProperty = null;
        modalPhotoUrls = null;
        Navigation.NavigateTo($"/booking/{id}");
    }

    public void Dispose()
    {
        foreach (var timer in cardPhotoTimers.Values)
        {
            timer.Dispose();
        }
        cardPhotoTimers.Clear();
    }
}