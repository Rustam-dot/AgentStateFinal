@page "/my-showings"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Client")]
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<div class="showings-page">
    <!-- Animated Background -->
    <div class="bg-gradient"></div>
    
    <div class="showings-container">
        <!-- Header -->
        <div class="page-header animate-fade-in">
            <div class="header-left">
                <h1 class="page-title">Мои <span class="purple-text">показы</span></h1>
                <p class="page-subtitle">История ваших просмотров и запланированные встречи</p>
            </div>
            <div class="stats-row">
                <div class="stat-chip">
                    <i class="fas fa-clock"></i>
                    <span>@upcomingCount предстоящих</span>
                </div>
                <div class="stat-chip completed">
                    <i class="fas fa-check"></i>
                    <span>@completedCount завершено</span>
                </div>
            </div>
        </div>

        @if (showings == null)
        {
            <div class="loader-container">
                <div class="premium-spinner"></div>
            </div>
        }
        else if (!showings.Any())
        {
            <div class="empty-state animate-fade-in">
                <div class="empty-icon">
                    <i class="fas fa-calendar-times"></i>
                </div>
                <h3>Пока ничего не запланировано</h3>
                <p>Ваша история показов пуста. Выберите объект в каталоге, чтобы записаться на просмотр.</p>
                <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/properties")'>
                    <i class="fas fa-search"></i>
                    <span>Перейти к поиску</span>
                </button>
            </div>
        }
        else
        {
            <!-- Filters -->
            <div class="filters-bar animate-fade-in" style="animation-delay: 0.1s;">
                <div class="filter-group">
                    <button class="filter-btn @(filterStatus == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
                        Все показы
                    </button>
                    <button class="filter-btn @(filterStatus == "upcoming" ? "active" : "")" @onclick='() => SetFilter("upcoming")'>
                        Предстоящие
                    </button>
                    <button class="filter-btn @(filterStatus == "completed" ? "active" : "")" @onclick='() => SetFilter("completed")'>
                        Завершённые
                    </button>
                </div>
            </div>

            <!-- Showings List -->
            <div class="showings-list">
                @foreach (var showing in FilteredShowings)
                {
                    <div class="showing-card animate-fade-up">
                        <div class="card-header">
                            <div class="date-badge @(showing.IsPast ? "past" : "upcoming")">
                                <div class="date-day">@showing.ShowingDateTime.ToString("dd")</div>
                                <div class="date-month">@showing.ShowingDateTime.ToString("MMM")</div>
                                <div class="date-time">@showing.ShowingDateTime.ToString("HH:mm")</div>
                            </div>
                            <div class="status-badge @GetStatusClass(showing)">
                                <i class="fas @GetStatusIcon(showing)"></i>
                                <span>@GetStatusText(showing)</span>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="property-info">
                                <h3 class="property-title">@showing.PropertyAddress</h3>
                                @if (!string.IsNullOrWhiteSpace(showing.Comments))
                                {
                                    <p class="property-comments">
                                        <i class="fas fa-comment"></i>
                                        @showing.Comments
                                    </p>
                                }
                            </div>

                            <div class="realtor-info">
                                <div class="realtor-avatar">
                                    @if (!string.IsNullOrWhiteSpace(showing.RealtorAvatarUrl))
                                    {
                                        <img src="@showing.RealtorAvatarUrl" alt="@showing.RealtorName" class="realtor-avatar-img" />
                                    }
                                    else
                                    {
                                        @(showing.RealtorName?.Substring(0, 1).ToUpper() ?? "Р")
                                    }
                                </div>
                                <div class="realtor-details">
                                    <span class="realtor-label">Риелтор</span>
                                    <span class="realtor-name">@showing.RealtorName</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">
                            @if (showing.CanDeal)
                            {
                                @if (processingShowings.Contains(showing.ShowingId))
                                {
                                    <button class="btn-deal btn-deal-processing" disabled>
                                        <div class="spinner-small"></div>
                                        <span>Оформление...</span>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-deal" @onclick='() => GoToDeal(showing.ShowingId)'>
                                        <i class="fas fa-file-signature"></i>
                                        <span>Оформить сделку</span>
                                    </button>
                                }
                            }
                            else if (showing.ResultName != null)
                            {
                                <div class="info-badge">
                                    <i class="fas fa-check-circle"></i>
                                    <span>Результат: @GetResultText(showing.ResultName)</span>
                                </div>
                            }
                            else
                            {
                                <div class="info-badge pending">
                                    <i class="fas fa-clock"></i>
                                    <span>Ожидается встреча</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>-- ✅ Закрываем showings-page -->

<style>
    :root {
        --primary: #8b5cf6;
        --primary-dark: #7c3aed;
        --primary-light: #a78bfa;
        --primary-bg: #f5f3ff;
        --bg-page: #f8fafc;
        --bg-card: #ffffff;
        --text-dark: #0f172a;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --success: #10b981;
        --warning: #f59e0b;
        --shadow: 0 4px 6px rgba(0,0,0,0.05);
        --shadow-lg: 0 10px 30px rgba(139, 92, 246, 0.15);
    }

    .showings-page {
        min-height: 100vh;
        background: var(--bg-page);
        padding: 100px 40px 40px;
        position: relative;
    }

    .bg-gradient {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
    }

    .showings-container {
        max-width: 1000px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
        gap: 20px;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
        color: var(--text-dark);
    }

    .purple-text {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        color: var(--text-muted);
        margin: 4px 0 0;
        font-size: 1.1rem;
    }

    .stats-row {
        display: flex;
        gap: 12px;
    }

    .stat-chip {
        background: white;
        border: 2px solid var(--border);
        padding: 10px 20px;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-muted);
        transition: all 0.3s;
    }

    .stat-chip i {
        color: var(--primary);
    }

    .stat-chip.completed {
        border-color: var(--success);
        color: var(--success);
    }

    .stat-chip.completed i {
        color: var(--success);
    }

    .filters-bar {
        margin-bottom: 32px;
        padding: 20px;
        background: white;
        border-radius: 16px;
        box-shadow: var(--shadow);
    }

    .filter-group {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 10px 24px;
        border: 2px solid var(--border);
        background: white;
        color: var(--text-muted);
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .filter-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .filter-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .showings-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .showing-card {
        background: var(--bg-card);
        border-radius: 20px;
        border: 1px solid var(--border);
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: var(--shadow);
    }

    .showing-card:hover {
        border-color: var(--primary);
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .card-header {
        padding: 20px 28px;
        background: var(--primary-bg);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--border);
    }

    .date-badge {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 20px;
        background: white;
        border-radius: 12px;
        box-shadow: var(--shadow);
    }

    .date-badge.upcoming {
        border-left: 4px solid var(--primary);
    }

    .date-badge.past {
        border-left: 4px solid var(--text-muted);
        opacity: 0.7;
    }

    .date-day {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1;
    }

    .date-month {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
    }

    .date-time {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-muted);
        padding-left: 16px;
        border-left: 2px solid var(--border);
    }

    .status-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .status-badge.pending {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning);
    }

    .status-badge.completed {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .status-badge.interested {
        background: rgba(139, 92, 246, 0.1);
        color: var(--primary);
    }

    .card-body {
        padding: 28px;
    }

    .property-info {
        margin-bottom: 24px;
    }

    .property-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 12px 0;
    }

    .property-comments {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 0;
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }

    .property-comments i {
        color: var(--primary);
        margin-top: 4px;
    }

    .realtor-info {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        background: var(--bg-page);
        border-radius: 12px;
    }

    .realtor-avatar {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        overflow: hidden;
        flex-shrink: 0;
    }

    .realtor-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .realtor-details {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .realtor-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        font-weight: 600;
    }

    .realtor-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    .card-footer {
        padding: 20px 28px;
        background: var(--bg-page);
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
    }

    .btn-deal {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }

    .btn-deal:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    .info-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .info-badge i {
        color: var(--primary);
    }

    .info-badge.pending i {
        color: var(--warning);
    }

    .loader-container {
        text-align: center;
        padding: 100px 20px;
    }

    .premium-spinner {
        width: 50px;
        height: 50px;
        border: 3px solid var(--primary-bg);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s infinite linear;
    }

    .empty-state {
        text-align: center;
        padding: 100px 40px;
        background: white;
        border-radius: 24px;
        border: 2px dashed var(--border);
    }

    .empty-icon {
        width: 100px;
        height: 100px;
        background: var(--primary-bg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }

    .empty-icon i {
        font-size: 3rem;
        color: var(--primary);
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 12px;
    }

    .empty-state p {
        color: var(--text-muted);
        font-size: 1.05rem;
        margin: 0 0 32px;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in {
        animation: fadeIn 0.6s ease forwards;
    }

    .animate-fade-up {
        opacity: 0;
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@media (max-width: 768px) {
        .showings-page {
            padding: 80px 20px 20px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .page-title {
            font-size: 1.8rem;
        }

        .stats-row {
            width: 100%;
        }

        .card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .date-badge {
            width: 100%;
            justify-content: space-between;
        }

        .card-body {
            padding: 20px;
        }

        .realtor-info {
            flex-direction: column;
            text-align: center;
        }

        .card-footer {
            padding: 16px 20px;
        }

        .btn-deal {
            width: 100%;
            justify-content: center;
        }
    }

    .btn-deal-processing {
        opacity: 0.7;
        cursor: not-allowed;
        background: var(--primary-light);
    }
    
    .btn-deal-processing:hover {
        transform: none;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }
    
    .spinner-small {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-right: 8px;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private List<MyShowingDto>? showings;
    private string filterStatus = "all";
    // 👇 НОВОЕ: отслеживаем показы, по которым уже начато оформление
    private HashSet<int> processingShowings = new();

    private int upcomingCount => showings?.Count(s => !s.IsPast && s.ResultName == null) ?? 0;
    private int completedCount => showings?.Count(s => s.ResultName != null) ?? 0;

    private IEnumerable<MyShowingDto> FilteredShowings
    {
        get
        {
            if (showings == null) return new List<MyShowingDto>();
            
            return filterStatus switch
            {
                "upcoming" => showings.Where(s => !s.IsPast && s.ResultName == null),
                "completed" => showings.Where(s => s.ResultName != null),
                _ => showings.OrderByDescending(s => s.ShowingDateTime)
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadShowings();
    }

    private async Task LoadShowings()
    {
        try
        {
            await Task.Delay(300);
            showings = await Http.GetFromJsonAsync<List<MyShowingDto>>("showings/my");
            
            // 👇 При перезагрузке очищаем список обработки
            processingShowings.Clear();
        }
        catch
        {
            showings = new();
        }
    }

    private void SetFilter(string status)
    {
        filterStatus = status;
    }

    private string GetStatusClass(MyShowingDto showing)
    {
        if (showing.ResultName != null)
        {
            return showing.ResultName.ToLower() switch
            {
                "completed" or "interested" => "completed",
                _ => "pending"
            };
        }
        return showing.IsPast ? "pending" : "pending";
    }

    private string GetStatusIcon(MyShowingDto showing)
    {
        if (showing.ResultName != null)
        {
            return showing.ResultName.ToLower() switch
            {
                "completed" => "fa-check-circle",
                "interested" => "fa-heart",
                _ => "fa-clock"
            };
        }
        return showing.IsPast ? "fa-clock" : "fa-clock";
    }

    private string GetStatusText(MyShowingDto showing)
    {
        if (showing.ResultName != null)
        {
            return showing.ResultName.ToLower() switch
            {
                "completed" => "Завершён",
                "interested" => "Заинтересован",
                "refused" => "Отказ",
                "postponed" => "Перенесён",
                "noshow" => "Неявка",
                _ => showing.ResultName
            };
        }
        return showing.IsPast ? "Прошёл" : "Запланирован";
    }

    private string GetResultText(string resultName)
    {
        return resultName.ToLower() switch
        {
            "completed" => "Завершён",
            "interested" => "Заинтересован",
            "refused" => "Отказ",
            "postponed" => "Перенесён",
            "noshow" => "Неявка",
            _ => resultName
        };
    }

    private void GoToDeal(int showingId)
    {
        // 👇 Добавляем показ в список обрабатываемых
        processingShowings.Add(showingId);
        
        // Небольшая задержка для визуального эффекта перед переходом
        Task.Delay(300).ContinueWith(_ => 
        {
            Navigation.NavigateTo($"/deals/create?showingId={showingId}");
        });
    }

    public class MyShowingDto
    {
        public int ShowingId { get; set; }
        public DateTime ShowingDateTime { get; set; }
        public string PropertyAddress { get; set; } = "";
        public string RealtorName { get; set; } = "";
        public string? RealtorAvatarUrl { get; set; }
        public string? ResultName { get; set; }
        public string? Comments { get; set; }
        public bool CanDeal { get; set; }
        public bool IsPast => ShowingDateTime < DateTime.Now;
    }
}