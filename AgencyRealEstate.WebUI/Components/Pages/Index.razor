@page "/"
@rendermode InteractiveServer
@using AgencyRealEstate.WebUI.Services
@using AgencyRealEstate.WebUI.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject ApiClient ApiClient
@inject NavigationManager Navigation
@attribute [Authorize]

<div class="main-container">
    <!-- Header с роль-зависимой навигацией -->
    <header class="main-header">
        <div class="header-content">
            <div class="logo" @onclick='() => Navigation.NavigateTo("/")' style="cursor: pointer;">
                <i class="fas fa-home"></i>
                <span>РеалтиПро</span>
            </div>
            
            <nav class="main-nav">
                <a href="/properties" class="nav-link">Каталог</a>
                <AuthorizeView Roles="Administrator,Manager">
                    <Authorized>
                        <a href="/reports" class="nav-link">Отчёты</a>
                    </Authorized>
                </AuthorizeView>
                <a href="/about" class="nav-link">О нас</a>
                <a href="/contacts" class="nav-link">Контакты</a>
            </nav>
            
            <AuthorizeView>
                <Authorized>
                    <div class="user-menu">
                        <a href="/profile" class="btn-profile">
                            <i class="fas fa-user"></i>
                            <span>Профиль</span>
                        </a>
                        <a href="/logout" class="btn-logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="auth-buttons">
                        <a href="/login" class="btn-login">Вход</a>
                        <a href="/register" class="btn-register">Регистрация</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-block">
        <div class="hero-content">
            <AuthorizeView>
                <Authorized>
                    <div class="user-greeting fade-in">
                        Добро пожаловать, <b>@context.User.Identity?.Name</b>!
                    </div>
                </Authorized>
            </AuthorizeView>

            <h1 class="hero-title animate-slide-up">
                Найдите <span class="gradient-text">Дом Мечты</span>
            </h1>
            <p class="hero-subtitle animate-slide-up delay-100">
                Современная платформа для поиска и продажи недвижимости<br/>
                премиум-класса
            </p>
            
            <div class="search-bar animate-slide-up delay-200">
                <div class="search-input-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" placeholder="Поиск по городу, району или адресу..." 
                           @bind="searchQuery" 
                           @onkeydown="OnKeyDown" />
                </div>
                <button class="search-btn" @onclick="Search">Найти</button>
            </div>

            <!-- Stats Grid -->
            <div class="stats-grid">
                <div class="stat-item animate-slide-up delay-300">
                    <div class="stat-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <div class="stat-info">
                        <h3>1000+ Объектов</h3>
                        <p>В нашей базе недвижимости</p>
                    </div>
                </div>
                <div class="stat-item animate-slide-up delay-400">
                    <div class="stat-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <div class="stat-info">
                        <h3>Опытные Агенты</h3>
                        <p>Профессиональная поддержка</p>
                    </div>
                </div>
                <div class="stat-item animate-slide-up delay-500">
                    <div class="stat-icon">
                        <i class="fas fa-award"></i>
                    </div>
                    <div class="stat-info">
                        <h3>10+ Лет</h3>
                        <p>Успешной работы на рынке</p>
                    </div>
                </div>
                <div class="stat-item animate-slide-up delay-600">
                    <div class="stat-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="stat-info">
                        <h3>98% Сделок</h3>
                        <p>Завершены успешно</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Properties -->
    <div class="page-wrapper">
        <div class="section-header">
            <div class="title-area">
                <h2 class="section-title">Избранные Объекты</h2>
                <p class="section-subtitle">Лучшие предложения этого месяца</p>
            </div>
            <a href="/properties" class="view-all-link">
                Все объекты <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        <div class="property-grid">
            @if (popularProperties == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton-card"></div>
                }
            }
            else if (!popularProperties.Any())
            {
                <div class="empty-state">
                    <h3>Ничего не найдено</h3>
                </div>
            }
            else
            {
                @foreach (var prop in popularProperties.Take(3))
                {
                    <div class="property-card animate-slide-up">
                        <div class="card-image-box">
                            @if (prop.PhotoUrls != null && prop.PhotoUrls.Any())
                            {
                                <img src="@prop.PhotoUrls.First()" alt="@prop.Title" />
                            }
                            else
                            {
                                <div class="no-photo-placeholder">
                                    <i class="fas fa-image"></i>
                                </div>
                            }
                            <div class="price-badge">@prop.Price?.ToString("N0") ₽</div>
                        </div>
                        <div class="card-body">
                            <h3 class="card-title">@prop.Title</h3>
                            <div class="card-location">
                                <i class="fas fa-map-marker-alt"></i> 
                                @prop.Address
                            </div>
                            
                            <div class="card-specs">
                                <div class="spec-item">
                                    <i class="fas fa-bed"></i> 
                                    <span>@prop.Rooms спальни</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-bath"></i> 
                                    <span>@prop.Bathrooms ванные</span>
                                </div>
                                <div class="spec-item">
                                    <i class="fas fa-ruler-combined"></i> 
                                    <span>@prop.TotalArea м²</span>
                                </div>
                            </div>

                            <AuthorizeView Roles="Client">
                                <Authorized>
                                    <a href="/properties/@prop.PropertyID" class="btn-action">
                                        Записаться на показ
                                    </a>
                                </Authorized>
                                <NotAuthorized>
                                    <button class="btn-action btn-action-disabled" disabled title="Требуется вход">
                                        Записаться на показ
                                    </button>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="footer-content">
            <div class="footer-logo">
                <i class="fas fa-home"></i>
                <span>РеалтиПро</span>
            </div>
            <p>Ваш надежный партнер в мире недвижимости</p>
            <div class="footer-links">
                <a href="/about">О компании</a>
                <a href="/contacts">Контакты</a>
                <a href="/privacy">Политика</a>
            </div>
            <p class="footer-copyright">© 2024 РеалтиПро. Все права защищены.</p>
        </div>
    </footer>
</div>

<style>
    :root {
        --primary: #7c3aed;
        --primary-light: #f3e8ff;
        --primary-hover: #6d28d9;
        --bg-light: #f8fafc;
        --text-dark: #0f172a;
        --text-muted: #64748b;
        --card-bg: #ffffff;
        --border-color: #e2e8f0;
        --danger: #ef4444;
        --hero-gradient-start: #ffffff;
        --stat-item-shadow: rgba(0,0,0,0.02);
        --search-bar-shadow: rgba(0,0,0,0.08);
        --search-bar-focus-shadow: rgba(124, 58, 237, 0.15);
        --card-hover-transform: translateY(-8px);
        --card-hover-shadow: rgba(124, 58, 237, 0.15);
    }

    [data-theme="dark"] {
        --primary: #a78bfa;
        --primary-light: #2e1a47;
        --primary-hover: #8b5cf6;
        --bg-light: #0f0a1e;
        --text-dark: #f0e6ff;
        --text-muted: #94a3b8;
        --card-bg: #1e1540;
        --border-color: #334155;
        --danger: #f87171;
        --hero-gradient-start: #1e1540;
        --stat-item-shadow: rgba(0,0,0,0.2);
        --search-bar-shadow: rgba(0,0,0,0.3);
        --search-bar-focus-shadow: rgba(167, 139, 250, 0.3);
        --card-hover-transform: translateY(-8px);
        --card-hover-shadow: rgba(167, 139, 250, 0.2);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body { 
        background-color: var(--bg-light); 
        color: var(--text-dark); 
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        line-height: 1.6;
    }

    .main-container { 
        background: var(--bg-light); 
        min-height: 100vh;
    }

    /* Header */
    .main-header {
        background: var(--card-bg);
        border-bottom: 1px solid var(--border-color);
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .header-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
    }

    .main-nav {
        display: flex;
        gap: 24px;
    }

    .nav-link {
        color: var(--text-dark);
        text-decoration: none;
        font-weight: 500;
        padding: 8px 4px;
        border-bottom: 2px solid transparent;
        transition: all 0.2s;
    }

    .nav-link:hover {
        color: var(--primary);
        border-bottom-color: var(--primary);
    }

    .user-menu {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-profile {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-profile:hover {
        background: var(--primary);
        color: white;
    }

    .btn-logout {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: 2px solid var(--border-color);
        background: var(--card-bg);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-logout:hover {
        border-color: var(--danger);
        color: var(--danger);
    }

    .auth-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-login {
        padding: 10px 24px;
        border: none;
        background: transparent;
        color: var(--text-dark);
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-login:hover {
        background: var(--bg-light);
    }

    .btn-register {
        padding: 10px 24px;
        border: none;
        background: var(--primary);
        color: white;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-register:hover {
        background: var(--primary-hover);
        transform: translateY(-1px);
    }

    /* Hero Section */
    .hero-block {
        padding: 80px 20px 60px;
        background: radial-gradient(circle at center top, var(--hero-gradient-start) 0%, var(--bg-light) 100%);
        text-align: center;
    }

    .hero-content { 
        max-width: 1000px; 
        margin: 0 auto; 
    }

    .user-greeting { 
        margin-bottom: 20px; 
        color: var(--text-muted); 
        font-size: 0.95rem; 
    }

    .hero-title { 
        font-size: 3.5rem; 
        font-weight: 800; 
        margin-bottom: 16px; 
        color: var(--text-dark);
        letter-spacing: -1px;
        line-height: 1.2;
    }

    .gradient-text { 
        background: linear-gradient(135deg, var(--primary), var(--primary-hover));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
    }
    
    .hero-subtitle { 
        font-size: 1.125rem; 
        color: var(--text-muted); 
        margin-bottom: 48px; 
        line-height: 1.6; 
    }

    /* Search Bar */
    .search-bar {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        padding: 8px;
        border-radius: 100px;
        display: flex;
        align-items: center;
        max-width: 700px;
        margin: 0 auto 60px;
        box-shadow: 0 10px 40px var(--search-bar-shadow);
        transition: all 0.3s;
    }

    .search-bar:focus-within { 
        border-color: var(--primary); 
        box-shadow: 0 10px 40px var(--search-bar-focus-shadow); 
    }
    
    .search-input-wrapper { 
        flex: 1; 
        display: flex; 
        align-items: center; 
        gap: 12px;
        padding-left: 20px;
    }

    .search-icon { 
        color: var(--text-muted);
        font-size: 1.1rem;
    }

    .search-input-wrapper input { 
        border: none; 
        outline: none; 
        width: 100%; 
        font-size: 1rem; 
        color: var(--text-dark); 
        background: transparent;
        padding: 12px 0;
    }

    .search-input-wrapper input::placeholder { 
        color: var(--text-muted); 
    }
    
    .search-btn {
        background: var(--primary); 
        color: var(--text-inverse, #fff); 
        border: none; 
        padding: 14px 32px;
        border-radius: 100px; 
        font-weight: 600; 
        font-size: 1rem;
        cursor: pointer; 
        transition: all 0.3s;
    }

    .search-btn:hover { 
        background: var(--primary-hover); 
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    /* Stats Grid */
    .stats-grid {
        display: grid; 
        grid-template-columns: repeat(4, 1fr); 
        gap: 24px;
        margin-top: 40px;
    }

    .stat-item {
        background: var(--card-bg); 
        padding: 28px; 
        border-radius: 20px;
        border: 1px solid var(--border-color); 
        display: flex; 
        align-items: flex-start; 
        gap: 16px;
        box-shadow: 0 4px 6px var(--stat-item-shadow); 
        text-align: left;
        transition: all 0.3s;
        opacity: 0;
        transform: translateY(30px);
        animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .stat-item:nth-child(1) { animation-delay: 0.3s; }
    .stat-item:nth-child(2) { animation-delay: 0.4s; }
    .stat-item:nth-child(3) { animation-delay: 0.5s; }
    .stat-item:nth-child(4) { animation-delay: 0.6s; }

    .stat-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px var(--card-hover-shadow);
    }

    .stat-icon {
        background: var(--primary-light); 
        color: var(--primary); 
        width: 52px; 
        height: 52px;
        border-radius: 14px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 1.4rem; 
        flex-shrink: 0;
    }

    .stat-info h3 { 
        font-size: 1.125rem; 
        font-weight: 700; 
        margin: 0 0 6px; 
        color: var(--text-dark); 
    }

    .stat-info p { 
        margin: 0; 
        font-size: 0.875rem; 
        color: var(--text-muted); 
        line-height: 1.5; 
    }

    /* Page Wrapper */
    .page-wrapper { 
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 40px 20px 80px; 
    }

    /* Section Header */
    .section-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: flex-end; 
        margin-bottom: 40px; 
    }

    .section-title { 
        font-size: 2rem; 
        font-weight: 800; 
        margin: 0 0 8px; 
        color: var(--text-dark); 
    }

    .section-subtitle { 
        color: var(--text-muted); 
        margin: 0;
        font-size: 0.95rem;
    }

    .view-all-link { 
        color: var(--primary); 
        text-decoration: none; 
        font-weight: 600; 
        display: flex; 
        align-items: center; 
        gap: 6px; 
        transition: all 0.2s; 
    }

    .view-all-link:hover { 
        color: var(--primary-hover);
        gap: 10px;
    }

    /* Property Grid */
    .property-grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 32px; 
    }
    
    .property-card {
        background: var(--card-bg); 
        border-radius: 24px; 
        overflow: hidden;
        border: 1px solid var(--border-color); 
        box-shadow: 0 4px 15px var(--stat-item-shadow);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        opacity: 0;
        transform: translateY(40px);
        animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .property-card:nth-child(1) { animation-delay: 0.7s; }
    .property-card:nth-child(2) { animation-delay: 0.8s; }
    .property-card:nth-child(3) { animation-delay: 0.9s; }

    .property-card:hover { 
        transform: var(--card-hover-transform); 
        box-shadow: 0 20px 40px var(--card-hover-shadow); 
        border-color: rgba(124, 58, 237, 0.3);
    }

    .card-image-box { 
        height: 260px; 
        position: relative; 
        overflow: hidden;
        padding: 16px;
        padding-bottom: 0;
    }

    .card-image-box img { 
        width: 100%; 
        height: 100%; 
        object-fit: cover; 
        border-radius: 16px 16px 0 0;
        transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .property-card:hover .card-image-box img {
        transform: scale(1.05);
    }
    
    .price-badge {
        position: absolute; 
        top: 28px; 
        right: 28px; 
        background: var(--primary); 
        color: var(--text-inverse, #fff);
        padding: 8px 16px; 
        border-radius: 12px; 
        font-size: 0.875rem; 
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }

    .card-body { 
        padding: 24px; 
    }

    .card-title { 
        font-size: 1.25rem; 
        font-weight: 700; 
        margin: 0 0 10px; 
        color: var(--text-dark);
    }

    .card-location { 
        color: var(--text-muted); 
        font-size: 0.9rem; 
        margin-bottom: 20px; 
        display: flex; 
        align-items: center; 
        gap: 6px; 
    }
    
    .card-specs { 
        display: flex; 
        justify-content: space-between; 
        border-top: 1px solid var(--border-color); 
        padding-top: 20px; 
        margin-bottom: 20px; 
    }

    .spec-item { 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        color: var(--text-muted); 
        font-size: 0.875rem; 
    }

    .spec-item i { 
        color: var(--primary); 
        font-size: 0.9rem;
    }

    .btn-action {
        display: block; 
        width: 100%; 
        text-align: center; 
        background: var(--primary-light);
        color: var(--primary); 
        font-weight: 600; 
        padding: 14px; 
        border-radius: 12px;
        text-decoration: none; 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid transparent;
        cursor: pointer;
    }

    .btn-action:hover:not(:disabled) { 
        background: var(--primary); 
        color: var(--text-inverse, #fff);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(124, 58, 237, 0.25);
    }
    
    .btn-action-disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    
    .btn-action-disabled:hover {
        transform: none;
        box-shadow: none;
    }

    /* Footer */
    .main-footer {
        background: var(--primary);
        color: white;
        padding: 60px 20px 40px;
        text-align: center;
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .footer-content > p {
        opacity: 0.9;
        margin-bottom: 24px;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        gap: 32px;
        margin-bottom: 24px;
    }

    .footer-links a {
        color: white;
        text-decoration: none;
        opacity: 0.9;
        transition: opacity 0.2s;
    }

    .footer-links a:hover {
        opacity: 1;
    }
    
    .footer-copyright {
        opacity: 0.7;
        font-size: 0.875rem;
        margin: 0;
    }

    /* Skeleton Loading */
    .skeleton-card { 
        height: 480px; 
        background: linear-gradient(90deg, var(--border-color) 25%, var(--bg-secondary, #f1f5f9) 50%, var(--border-color) 75%);
        background-size: 200% 100%;
        border-radius: 24px; 
        animation: shimmer 1.5s infinite; 
    }

    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* Animations */
    .animate-slide-up {
        opacity: 0;
        transform: translateY(40px);
        animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-500 { animation-delay: 0.5s; }
    .delay-600 { animation-delay: 0.6s; }

    @@keyframes slideUpFade {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .property-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .hero-title {
            font-size: 2.5rem;
        }
    }

    @@media (max-width: 768px) {
        .header-content {
            flex-wrap: wrap;
            gap: 16px;
