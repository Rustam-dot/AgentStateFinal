@code {
    string searchQuery = "";
    List<PropertyDto>? allProperties;
    List<PropertyDto>? popularProperties;
    private bool _isSearchFocused = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allProperties = await ApiClient.GetPropertiesAsync();
            popularProperties = allProperties?.Take(3).ToList() ?? new(); 
        }
        catch
        {
            allProperties = new();
            popularProperties = new();
        }
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Search();
    }

    private void Search()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return;
        var encoded = Uri.EscapeDataString(searchQuery);
        Navigation.NavigateTo($"/properties?search={encoded}");
    }

    private void QuickSearch(string query)
    {
        searchQuery = query;
        Search();
    }
}