@page "/"
@rendermode InteractiveServer
@using AgencyRealEstate.WebUI.Services
@using AgencyRealEstate.WebUI.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject ApiClient ApiClient
@inject NavigationManager Navigation
@attribute [Authorize]

<div class="main-container">
    <!-- Анимированный фон (общий для страницы) -->
    <div class="ambient-bg">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
    </div>

    <!-- Header -->
    <header class="main-header" id="mainHeader">
        <div class="header-content">
            <div class="logo" @onclick='() => Navigation.NavigateTo("/")'>
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                </div>
                <span>РеалтиПро</span>
            </div>
            
            <nav class="main-nav">
                <a href="/properties" class="nav-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    Каталог
                </a>
                <AuthorizeView Roles="Administrator,Manager">
                    <Authorized>
                        <a href="/reports" class="nav-link">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                            Отчёты
                        </a>
                    </Authorized>
                </AuthorizeView>
                <a href="/about" class="nav-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                    О нас
                </a>
                <a href="/contacts" class="nav-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                    Контакты
                </a>
            </nav>
            
            <AuthorizeView>
                <Authorized>
                    <div class="user-menu">
                        <a href="/profile" class="btn-profile">
                            <div class="avatar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            </div>
                            <span>@context.User.Identity?.Name</span>
                        </a>
                        <a href="/logout" class="btn-logout" title="Выйти">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                        </a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="auth-buttons">
                        <a href="/login" class="btn-login">Вход</a>
                        <a href="/register" class="btn-register">Регистрация</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <!-- Hero Section с абстрактным дизайном -->
    <section class="hero-block">
        <!-- Абстрактный фон вместо фото (Слой 0) -->
        <div class="hero-abstract-bg">
            <div class="abstract-shape shape-1"></div>
            <div class="abstract-shape shape-2"></div>
            <div class="abstract-shape shape-3"></div>
            <div class="abstract-grid"></div>
            <div class="abstract-glow"></div>
        </div>

        <!-- Контент (Слой 2, чтобы быть поверх фона) -->
        <div class="hero-content">
            <AuthorizeView>
                <Authorized>
                    <div class="user-greeting">
                        <span class="greeting-badge">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            Добро пожаловать, <b>@context.User.Identity?.Name</b>
                        </span>
                    </div>
                </Authorized>
            </AuthorizeView>

            <h1 class="hero-title">
                Найдите 
                <span class="gradient-text-wrapper">
                    <span class="gradient-text">Дом Мечты</span>
                    <svg class="underline-svg" viewBox="0 0 200 12" preserveAspectRatio="none">
                        <path d="M0,8 Q50,0 100,8 T200,8" fill="none" stroke="url(#gradient)" stroke-width="3" stroke-linecap="round"/>
                        <defs>
                            <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" style="stop-color:#7c3aed"/>
                                <stop offset="100%" style="stop-color:#a78bfa"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </span>
            </h1>
            
            <p class="hero-subtitle">
                Современная платформа для поиска и продажи недвижимости премиум-класса
            </p>
            
            <!-- Улучшенная поисковая строка -->
            <div class="search-container">
                <div class="search-bar @(_isSearchFocused ? "focused" : "")">
                    <div class="search-input-wrapper">
                        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" 
                               placeholder="Поиск по городу, району или адресу..." 
                               @bind="searchQuery" 
                               @onkeydown="OnKeyDown"
                               @onfocus="() => _isSearchFocused = true"
                               @onblur="() => _isSearchFocused = false" />
                        @if (!string.IsNullOrEmpty(searchQuery))
                        {
                            <button class="clear-btn" @onclick="() => searchQuery = string.Empty">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            </button>
                        }
                    </div>
                    <button class="search-btn" @onclick="Search">
                        <span>Найти</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </button>
                </div>
                <div class="search-tags">
                    <span class="tag-label">Популярное:</span>
                    <button class="search-tag" @onclick='() => QuickSearch("Москва")'>Москва</button>
                    <button class="search-tag" @onclick='() => QuickSearch("Санкт-Петербург")'>Санкт-Петербург</button>
                    <button class="search-tag" @onclick='() => QuickSearch("Квартира")'>Квартиры</button>
                    <button class="search-tag" @onclick='() => QuickSearch("Дом")'>Дома</button>
                </div>
            </div>

            <!-- Stats с hover-эффектами -->
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-icon stat-icon-purple">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-counter" data-target="1247">1,247+</h3>
                        <p>Объектов в базе</p>
                    </div>
                    <div class="stat-glow"></div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon stat-icon-blue">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-counter" data-target="86">86</h3>
                        <p>Опытных агентов</p>
                    </div>
                    <div class="stat-glow"></div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon stat-icon-green">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-counter" data-target="12">12+</h3>
                        <p>Лет на рынке</p>
                    </div>
                    <div class="stat-glow"></div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon stat-icon-orange">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                    </div>
                    <div class="stat-info">
                        <h3 class="stat-counter" data-target="98">98%</h3>
                        <p>Успешных сделок</p>
                    </div>
                    <div class="stat-glow"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Properties -->
    <div class="page-wrapper">
        <div class="section-header">
            <div class="title-area">
                <div class="section-badge">Премиум</div>
                <h2 class="section-title">Избранные Объекты</h2>
                <p class="section-subtitle">Лучшие предложения этого месяца, отобранные нашими экспертами</p>
            </div>
            <a href="/properties" class="view-all-link">
                <span>Все объекты</span>
                <div class="arrow-circle">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
            </a>
        </div>

        <div class="property-grid">
            @if (popularProperties == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton-card">
                        <div class="skeleton-image"></div>
                        <div class="skeleton-content">
                            <div class="skeleton-line skeleton-title"></div>
                            <div class="skeleton-line skeleton-subtitle"></div>
                            <div class="skeleton-line skeleton-text"></div>
                            <div class="skeleton-footer">
                                <div class="skeleton-line skeleton-btn"></div>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (!popularProperties.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    </div>
                    <h3>Ничего не найдено</h3>
                    <p>Попробуйте изменить параметры поиска</p>
                </div>
            }
            else
            {
                @foreach (var prop in popularProperties.Take(3))
                {
                    <div class="property-card">
                        <div class="card-image-box">
                            @if (prop.PhotoUrls != null && prop.PhotoUrls.Any())
                            {
                                <img src="@prop.PhotoUrls.First()" alt="@prop.Title" loading="lazy" />
                            }
                            else
                            {
                                <div class="no-photo-placeholder">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                </div>
                            }
                            <div class="image-overlay"></div>
                            <div class="price-badge">
                                <span class="price-value">@prop.Price?.ToString("N0")</span>
                                <span class="price-currency">₽</span>
                            </div>
                            <div class="card-actions">
                                <button class="action-btn favorite-btn" title="В избранное">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                </button>
                                <button class="action-btn share-btn" title="Поделиться">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="card-header-row">
                                <h3 class="card-title">@prop.Title</h3>
                                <span class="card-type">@prop.PropertyTypeName</span>
                            </div>
                            <div class="card-location">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                @prop.Address
                            </div>
                            
                            <div class="card-specs">
                                <div class="spec-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20h.01"></path><path d="M7 20v-4"></path><path d="M12 20v-8"></path><path d="M17 20V8"></path><path d="M22 4v16"></path></svg>
                                    <span>@prop.Rooms <small>спальни</small></span>
                                </div>
                                <div class="spec-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"></path></svg>
                                    <span>@prop.Bathrooms <small>ванные</small></span>
                                </div>
                                <div class="spec-item">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
                                    <span>@prop.TotalArea <small>м²</small></span>
                                </div>
                            </div>

                            <div class="card-footer">
                                <AuthorizeView Roles="Client">
                                    <Authorized>
                                        <a href="/properties/@prop.PropertyID" class="btn-action">
                                            <span>Записаться на показ</span>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                                        </a>
                                    </Authorized>
                                    <NotAuthorized>
                                        <button class="btn-action btn-action-disabled" disabled title="Требуется вход">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                            <span>Требуется вход</span>
                                        </button>
                                    </NotAuthorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-content">
            <h2>Готовы найти свой идеальный дом?</h2>
            <p>Наши эксперты помогут вам на каждом этапе — от подбора до оформления сделки</p>
            <a href="/properties" class="cta-btn">
                <span>Начать поиск</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
        <div class="cta-decoration">
            <div class="cta-orb"></div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="main-footer">
        <div class="footer-content">
            <div class="footer-main">
                <div class="footer-brand">
                    <div class="logo-icon footer-logo-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                            <polyline points="9 22 9 12 15 12 15 22"></polyline>
                        </svg>
                    </div>
                    <span class="footer-brand-name">РеалтиПро</span>
                    <p class="footer-desc">Ваш надежный партнер в мире недвижимости. Профессиональный подход к каждой сделке.</p>
                </div>
                <div class="footer-links-group">
                    <h4>Навигация</h4>
                    <a href="/properties">Каталог</a>
                    <a href="/about">О компании</a>
                    <a href="/contacts">Контакты</a>
                </div>
                <div class="footer-links-group">
                    <h4>Информация</h4>
                    <a href="/privacy">Политика конфиденциальности</a>
                    <a href="/terms">Условия использования</a>
                    <a href="/faq">FAQ</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 РеалтиПро. Все права защищены.</p>
                <div class="footer-socials">
                    <a href="#" class="social-link"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
                    <a href="#" class="social-link"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
                    <a href="#" class="social-link"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    :root {
        --primary: #7c3aed;
        --primary-light: #f3e8ff;
        --primary-hover: #6d28d9;
        --primary-glow: rgba(124, 58, 237, 0.15);
        --bg-light: #f8fafc;
        --bg-white: #ffffff;
        --text-dark: #0f172a;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --text-light: #94a3b8;
        --card-bg: #ffffff;
        --border-color: #e2e8f0;
        --border-light: #f1f5f9;
        --danger: #ef4444;
        --success: #10b981;
        --warning: #f59e0b;
        --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
        --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        --shadow-primary: 0 4px 14px 0 rgba(124, 58, 237, 0.25);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body { 
        background-color: var(--bg-light); 
        color: var(--text-dark); 
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    .main-container { 
        background: var(--bg-light); 
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
    }

    /* === Анимированный фон === */
    .ambient-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.5;
        animation: orbFloat 20s ease-in-out infinite;
    }

    .orb-1 {
        width: 600px;
        height: 600px;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(168, 85, 247, 0.1));
        top: -10%;
        left: -10%;
        animation-delay: 0s;
    }

    .orb-2 {
        width: 500px;
        height: 500px;
        background: linear-gradient(135deg, rgba(124, 58, 237, 0.15), rgba(196, 181, 253, 0.1));
        bottom: 20%;
        right: -10%;
        animation-delay: -7s;
    }

    .orb-3 {
        width: 400px;
        height: 400px;
        background: linear-gradient(135deg, rgba(167, 139, 250, 0.1), rgba(139, 92, 246, 0.15));
        top: 40%;
        left: 30%;
        animation-delay: -14s;
    }

    @@keyframes orbFloat {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -30px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
    }

    /* === Header === */
    .main-header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(226, 232, 240, 0.6);
        padding: 0;
        position: sticky;
        top: 0;
        z-index: 1000;
        transition: all 0.3s ease;
    }

    .main-header.scrolled {
        box-shadow: var(--shadow-md);
        background: rgba(255, 255, 255, 0.95);
    }

    .header-content {
        max-width: 1280px;
        margin: 0 auto;
        padding: 12px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-dark);
        cursor: pointer;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        flex-shrink: 0;
    }

    .logo:hover {
        transform: scale(1.05);
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary), #a78bfa);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: var(--shadow-primary);
    }

    .logo-icon svg {
        width: 22px;
        height: 22px;
    }

    .main-nav {
        display: flex;
        gap: 4px;
        align-items: center;
    }

    .nav-link {
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 8px 16px;
        border-radius: 10px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .nav-link:hover {
        color: var(--primary);
        background: var(--primary-light);
    }

    .nav-link svg {
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .nav-link:hover svg {
        opacity: 1;
    }

    .user-menu {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .btn-profile {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 16px 8px 8px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .btn-profile:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        box-shadow: var(--shadow-primary);
    }

    .avatar {
        width: 28px;
        height: 28px;
        background: white;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-logout {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: 2px solid var(--border-color);
        background: white;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .btn-logout:hover {
        border-color: var(--danger);
        color: var(--danger);
        background: rgba(239, 68, 68, 0.05);
    }

    .auth-buttons {
        display: flex;
        gap: 12px;
        flex-shrink: 0;
    }

    .btn-login {
        padding: 10px 20px;
        border: 2px solid var(--border-color);
        background: transparent;
        color: var(--text-dark);
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border-radius: 10px;
        transition: all 0.2s;
        font-size: 0.9rem;
    }

    .btn-login:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
    }

    .btn-register {
        padding: 10px 20px;
        border: none;
        background: linear-gradient(135deg, var(--primary), #8b5cf6);
        color: white;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border-radius: 10px;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        box-shadow: var(--shadow-primary);
    }

    .btn-register:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(124, 58, 237, 0.35);
    }

    /* === Hero Section === */
    .hero-block {
        padding: 100px 24px 80px;
        text-align: center;
        position: relative;
        z-index: 1;
        overflow: hidden;
        /* Принудительно убираем любой фон, если он был задан в других CSS файлах */
        background: none !important;
        background-image: none !important;
    }

    /* Абстрактный фон вместо фото */
    .hero-abstract-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 0; /* Фон находится под контентом */
        overflow: hidden;
        background: linear-gradient(135deg, #f8fafc 0%, #f3e8ff 100%); /* Легкий градиент на фоне */
    }

    .abstract-shape {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.5;
        animation: shapeFloat 15s ease-in-out infinite;
    }

    .shape-1 {
        width: 500px;
        height: 500px;
        background: linear-gradient(135deg, rgba(124, 58, 237, 0.3), rgba(168, 85, 247, 0.2));
        top: -10%;
        right: -5%;
        animation-delay: 0s;
    }

    .shape-2 {
        width: 400px;
        height: 400px;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.25), rgba(196, 181, 253, 0.15));
        bottom: 10%;
        left: -5%;
        animation-delay: -5s;
    }

    .shape-3 {
        width: 300px;
        height: 300px;
        background: linear-gradient(135deg, rgba(167, 139, 250, 0.3), rgba(124, 58, 237, 0.2));
        top: 40%;
        left: 50%;
        transform: translateX(-50%);
        animation-delay: -10s;
    }

    .abstract-grid {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: 
            linear-gradient(rgba(124, 58, 237, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(124, 58, 237, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        opacity: 0.8;
    }

    .abstract-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 800px;
        height: 800px;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
        animation: glowPulse 8s ease-in-out infinite;
    }

    @@keyframes shapeFloat {
        0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
        33% { transform: translate(30px, -30px) scale(1.1) rotate(5deg); }
        66% { transform: translate(-20px, 20px) scale(0.9) rotate(-5deg); }
    }

    @@keyframes glowPulse {
        0%, 100% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
        50% { opacity: 0.7; transform: translate(-50%, -50%) scale(1.1); }
    }

    .hero-content { 
        max-width: 900px; 
        margin: 0 auto; 
        position: relative;
        z-index: 2; /* Контент выше фона */
    }

    .user-greeting { 
        margin-bottom: 24px; 
        animation: fadeInDown 0.8s ease-out;
    }

    .greeting-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        background: linear-gradient(135deg, var(--primary-light), rgba(139, 92, 246, 0.08));
        border: 1px solid rgba(124, 58, 237, 0.15);
        border-radius: 100px;
        color: var(--primary);
        font-size: 0.9rem;
        font-weight: 600;
        box-shadow: 0 2px 8px rgba(124, 58, 237, 0.1);
    }

    .greeting-badge b {
        color: var(--primary-hover);
    }

    .hero-title { 
        font-size: 4rem; 
        font-weight: 800; 
        margin-bottom: 20px; 
        color: var(--text-dark);
        letter-spacing: -2px;
        line-height: 1.1;
        animation: fadeInUp 0.8s ease-out 0.1s both;
    }

    .gradient-text-wrapper {
        position: relative;
        display: inline-block;
    }

    .gradient-text { 
        background: linear-gradient(135deg, var(--primary), #a78bfa, #c4b5fd);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientShift 5s ease infinite;
    }

    @@keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .underline-svg {
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 100%;
        height: 12px;
        animation: drawLine 1.5s ease-out 0.8s both;
    }

    @@keyframes drawLine {
        from { stroke-dasharray: 200; stroke-dashoffset: 200; opacity: 0; }
        to { stroke-dasharray: 200; stroke-dashoffset: 0; opacity: 1; }
    }
    
    .hero-subtitle { 
        font-size: 1.25rem; 
        color: var(--text-muted); 
        margin-bottom: 48px; 
        line-height: 1.7;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    /* === Search === */
    .search-container {
        max-width: 700px;
        margin: 0 auto 60px;
        animation: fadeInUp 0.8s ease-out 0.3s both;
    }

    .search-bar {
        background: var(--card-bg);
        border: 2px solid var(--border-color);
        padding: 6px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        box-shadow: var(--shadow-lg);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-bar.focused {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px var(--primary-glow), var(--shadow-xl);
        transform: translateY(-2px);
    }

    .search-input-wrapper { 
        flex: 1; 
        display: flex; 
        align-items: center; 
        gap: 12px;
        padding: 0 8px 0 16px;
    }

    .search-icon { 
        color: var(--text-light);
        flex-shrink: 0;
        transition: color 0.3s;
    }

    .search-bar.focused .search-icon {
        color: var(--primary);
    }

    .search-input-wrapper input { 
        border: none; 
        outline: none; 
        width: 100%; 
        font-size: 1rem; 
        color: var(--text-dark); 
        background: transparent;
        padding: 12px 0;
        font-weight: 500;
    }

    .search-input-wrapper input::placeholder { 
        color: var(--text-light); 
    }

    .clear-btn {
        background: none;
        border: none;
        color: var(--text-light);
        cursor: pointer;
        padding: 4px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .clear-btn:hover {
        background: var(--border-light);
        color: var(--text-dark);
    }
    
    .search-btn {
        background: linear-gradient(135deg, var(--primary), #8b5cf6); 
        color: #fff; 
        border: none; 
        padding: 14px 28px;
        border-radius: 12px; 
        font-weight: 600; 
        font-size: 1rem;
        cursor: pointer; 
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: var(--shadow-primary);
    }

    .search-btn:hover { 
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(124, 58, 237, 0.35);
    }

    .search-btn:active {
        transform: translateY(0);
    }

    .search-tags {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 16px;
        padding-left: 8px;
    }

    .tag-label {
        font-size: 0.85rem;
        color: var(--text-light);
        font-weight: 500;
    }

    .search-tag {
        padding: 6px 14px;
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 100px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 500;
    }

    .search-tag:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: var(--primary-light);
        box-shadow: var(--shadow-sm);
    }

    /* === Stats === */
    .stats-grid {
        display: grid; 
        grid-template-columns: repeat(4, 1fr); 
        gap: 20px;
        margin-top: 60px;
    }

    .stat-item {
        background: var(--card-bg); 
        padding: 28px; 
        border-radius: 20px;
        border: 1px solid var(--border-color); 
        display: flex; 
        align-items: flex-start; 
        gap: 16px;
        box-shadow: var(--shadow-sm);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.8s ease-out both;
    }

    .stat-item:nth-child(1) { animation-delay: 0.4s; }
    .stat-item:nth-child(2) { animation-delay: 0.5s; }
    .stat-item:nth-child(3) { animation-delay: 0.6s; }
    .stat-item:nth-child(4) { animation-delay: 0.7s; }

    .stat-item:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-xl);
        border-color: rgba(124, 58, 237, 0.2);
    }

    .stat-item:hover .stat-glow {
        opacity: 1;
    }

    .stat-icon {
        width: 52px; 
        height: 52px;
        border-radius: 14px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 1.4rem; 
        flex-shrink: 0;
        transition: transform 0.3s;
    }

    .stat-item:hover .stat-icon {
        transform: scale(1.1) rotate(-5deg);
    }

    .stat-icon-purple {
        background: linear-gradient(135deg, #f3e8ff, #ede9fe);
        color: var(--primary);
    }

    .stat-icon-blue {
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
        color: #3b82f6;
    }

    .stat-icon-green {
        background: linear-gradient(135deg, #d1fae5, #ecfdf5);
        color: #10b981;
    }

    .stat-icon-orange {
        background: linear-gradient(135deg, #ffedd5, #fff7ed);
        color: #f59e0b;
    }

    .stat-info h3 { 
        font-size: 1.5rem; 
        font-weight: 800; 
        margin: 0 0 4px; 
        color: var(--text-dark); 
        letter-spacing: -0.5px;
    }

    .stat-info p { 
        margin: 0; 
        font-size: 0.875rem; 
        color: var(--text-muted); 
        line-height: 1.5; 
        font-weight: 500;
    }

    .stat-glow {
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(124, 58, 237, 0.08) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.4s;
        pointer-events: none;
    }

    /* === Page Wrapper === */
    .page-wrapper { 
        max-width: 1280px; 
        margin: 0 auto; 
        padding: 60px 24px 80px; 
        position: relative;
        z-index: 1;
    }

    /* === Section Header === */
    .section-header { 
        display: flex; 
        justify-content: space-between; 
        align-items: flex-end; 
        margin-bottom: 40px; 
    }

    .title-area {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .section-badge {
        display: inline-flex;
        padding: 4px 12px;
        background: linear-gradient(135deg, var(--primary-light), rgba(139, 92, 246, 0.1));
        border: 1px solid rgba(124, 58, 237, 0.2);
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
    }

    .section-title { 
        font-size: 2.25rem; 
        font-weight: 800; 
        margin: 0; 
        color: var(--text-dark);
        letter-spacing: -1px;
    }

    .section-subtitle { 
        color: var(--text-muted); 
        margin: 0;
        font-size: 1rem;
        font-weight: 500;
    }

    .view-all-link { 
        color: var(--primary); 
        text-decoration: none; 
        font-weight: 600; 
        display: flex; 
        align-items: center; 
        gap: 10px; 
        transition: all 0.3s ease;
        padding: 8px;
        border-radius: 12px;
    }

    .view-all-link:hover { 
        background: var(--primary-light);
    }

    .arrow-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .view-all-link:hover .arrow-circle {
        background: var(--primary);
        color: white;
        transform: translateX(4px);
    }

    /* === Property Grid === */
    .property-grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); 
        gap: 28px; 
    }
    
    .property-card {
        background: var(--card-bg); 
        border-radius: 24px; 
        overflow: hidden;
        border: 1px solid var(--border-color); 
        box-shadow: var(--shadow-sm);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        animation: fadeInUp 0.8s ease-out both;
    }

    .property-card:nth-child(1) { animation-delay: 0.5s; }
    .property-card:nth-child(2) { animation-delay: 0.6s; }
    .property-card:nth-child(3) { animation-delay: 0.7s; }

    .property-card:hover { 
        transform: translateY(-8px); 
        box-shadow: 0 25px 50px -12px rgba(124, 58, 237, 0.15); 
        border-color: rgba(124, 58, 237, 0.2);
    }

    .card-image-box { 
        height: 260px; 
        position: relative; 
        overflow: hidden;
    }

    .card-image-box img { 
        width: 100%; 
        height: 100%; 
        object-fit: cover; 
        transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .property-card:hover .card-image-box img {
        transform: scale(1.08);
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.3) 0%, transparent 50%);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .property-card:hover .image-overlay {
        opacity: 1;
    }
    
    .price-badge {
        position: absolute; 
        top: 16px; 
        right: 16px; 
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        color: var(--text-dark);
        padding: 8px 16px; 
        border-radius: 12px; 
        font-weight: 700;
        box-shadow: var(--shadow-md);
        display: flex;
        align-items: baseline;
        gap: 2px;
        z-index: 2;
    }

    .price-value {
        font-size: 1rem;
    }

    .price-currency {
        font-size: 0.85rem;
        color: var(--primary);
    }

    .card-actions {
        position: absolute;
        top: 16px;
        left: 16px;
        display: flex;
        gap: 8px;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        z-index: 2;
    }

    .property-card:hover .card-actions {
        opacity: 1;
        transform: translateY(0);
    }

    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: none;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: var(--shadow-sm);
    }

    .action-btn:hover {
        background: white;
        color: var(--primary);
        transform: scale(1.1);
    }

    .favorite-btn:hover {
        color: #ef4444;
    }

    .no-photo-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--border-light), var(--border-color));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-light);
    }

    .card-body { 
        padding: 24px; 
    }

    .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 8px;
    }

    .card-title { 
        font-size: 1.125rem; 
        font-weight: 700; 
        margin: 0; 
        color: var(--text-dark);
        line-height: 1.4;
        flex: 1;
    }

    .card-type {
        padding: 4px 10px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        flex-shrink: 0;
    }

    .card-location { 
        color: var(--text-muted); 
        font-size: 0.875rem; 
        margin-bottom: 20px; 
        display: flex; 
        align-items: center; 
        gap: 6px; 
        font-weight: 500;
    }

    .card-location svg {
        color: var(--primary);
        flex-shrink: 0;
    }
    
    .card-specs { 
        display: flex; 
        justify-content: space-between; 
        border-top: 1px solid var(--border-light); 
        padding-top: 16px; 
        margin-bottom: 20px; 
    }

    .spec-item { 
        display: flex; 
        align-items: center; 
        gap: 8px; 
