@page "/add-property"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator,Manager,Realtor")]
@using System.Net.Http.Json
@inject HttpClient Http
@inject TokenStorage TokenStorage

<div class="add-property-page">
    <div class="container">
        <!-- Header -->
        <div class="page-header animate-fade-in">
            <div class="header-content">
                <h1 class="page-title">Добавление <span class="purple-text">объекта</span></h1>
                <p class="page-subtitle">Создание премиальной карточки недвижимости</p>
            </div>
        </div>

        <div class="content-grid">
            <!-- Left Column: Form -->
            <div class="form-section">
                <div class="form-card">
                    <EditForm Model="model" OnValidSubmit="SubmitProperty">
                        <DataAnnotationsValidator />

                        <div class="form-row">
                            <div class="form-group full-width">
                                <label>
                                    <i class="fas fa-heading"></i>
                                    Название объекта
                                </label>
                                <InputText @bind-Value="model.Title" class="form-input" placeholder="Например: Пентхаус с панорамным видом" />
                                <ValidationMessage For="@(() => model.Title)" class="error-text" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group full-width">
                                <label>
                                    <i class="fas fa-map-marker-alt"></i>
                                    Адрес объекта
                                </label>
                                <InputText @bind-Value="model.Address" class="form-input" placeholder="г. Москва, ул. Арбат, д. 1" />
                                <ValidationMessage For="@(() => model.Address)" class="error-text" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>
                                    <i class="fas fa-building"></i>
                                    Тип недвижимости
                                </label>
                                <select @bind="model.PropertyTypeId" class="form-select">
                                    <option value="0">-- Выберите --</option>
                                    <option value="17">Квартира</option>
                                    <option value="18">Вилла / Дом</option>
                                    <option value="19">Таунхаус</option>
                                    <option value="20">Коммерция</option>
                                    <option value="21">Участок</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>
                                    <i class="fas fa-tag"></i>
                                    Цена, ₽
                                </label>
                                <InputNumber @bind-Value="model.Price" class="form-input price-input" placeholder="0" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>
                                    <i class="fas fa-ruler-combined"></i>
                                    Общая площадь, м²
                                </label>
                                <InputNumber @bind-Value="model.TotalArea" class="form-input" placeholder="0" />
                            </div>

                            <div class="form-group">
                                <label>
                                    <i class="fas fa-couch"></i>
                                    Жилая площадь, м²
                                </label>
                                <InputNumber @bind-Value="model.LivingArea" class="form-input" placeholder="0" />
                            </div>

                            <div class="form-group">
                                <label>
                                    <i class="fas fa-door-open"></i>
                                    Комнат
                                </label>
                                <InputNumber @bind-Value="model.Rooms" class="form-input" placeholder="0" min="0" />
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>
                                    <i class="fas fa-bath"></i>
                                    Ванных комнат
                                </label>
                                <InputNumber @bind-Value="model.Bathrooms" class="form-input" placeholder="0" min="0" max="10" />
                            </div>

                            <div class="form-group">
                                <label>
                                    <i class="fas fa-layer-group"></i>
                                    Этаж
                                </label>
                                <div class="input-group">
                                    <InputNumber @bind-Value="model.Floor" class="form-input" placeholder="Этаж" />
                                    <span class="input-divider">/</span>
                                    <InputNumber @bind-Value="model.TotalFloors" class="form-input" placeholder="Всего" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label>
                                    <i class="fas fa-cubes"></i>
                                    Материал стен
                                </label>
                                <select @bind="model.WallMaterialId" class="form-select">
                                    <option value="">-- Не выбрано --</option>
                                    <option value="20">Кирпич</option>
                                    <option value="21">Панель</option>
                                    <option value="22">Монолит</option>
                                    <option value="23">Брус</option>
                                    <option value="24">Газобетон</option>
                                    <option value="25">Кирпично-монолитный</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group full-width">
                                <label>
                                    <i class="fas fa-align-left"></i>
                                    Описание объекта
                                </label>
                                <InputTextArea @bind-Value="model.Description" class="form-input form-textarea" rows="4" placeholder="Опишите преимущества объекта..." />
                            </div>
                        </div>

                        @if (createdPropertyId == null)
                        {
                            <button type="submit" class="btn-primary" disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <div class="spinner-small"></div>
                                }
                                <span>@(isProcessing ? "Создание..." : "СОЗДАТЬ ОБЪЕКТ")</span>
                            </button>
                        }
                    </EditForm>

                    @if (createdPropertyId != null)
                    {
                        <div class="upload-section animate-fade-in">
                            <div class="success-message">
                                <i class="fas fa-check-circle"></i>
                                <span>Объект #@createdPropertyId создан. Загрузите фото.</span>
                            </div>

                            <div class="upload-area">
                                <label class="upload-trigger">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <span class="upload-text">Выберите фотографии</span>
                                    <span class="upload-hint">До 10 изображений, JPG/PNG/WEBP</span>
                                    <InputFile OnChange="OnFilesSelected" multiple accept="image/*" class="hidden-input" />
                                </label>

                                @if (filePreviews.Count > 0)
                                {
                                    <div class="preview-grid">
                                        @foreach (var img in filePreviews)
                                        {
                                            <div class="preview-item">
                                                <img src="@img.Url" alt="preview" />
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <button class="btn-primary" @onclick="UploadPhotos" disabled="@(!originalFiles.Any() || isProcessing)">
                                @if (isProcessing)
                                {
                                    <div class="spinner-small"></div>
                                }
                                <span>@(isProcessing ? "Загрузка..." : "ЗАГРУЗИТЬ ФОТО И ОПУБЛИКОВАТЬ")</span>
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="status-message @(statusMessage.Contains("Ошибка") ? "error" : "success")">
                            <i class="fas @(statusMessage.Contains("Ошибка") ? "fa-exclamation-circle" : "fa-check-circle")"></i>
                            <span>@statusMessage</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Column: Preview -->
            <div class="preview-section">
                <div class="preview-card sticky">
                    <h3 class="preview-title">Предпросмотр</h3>
                    
                    <div class="property-card-preview">
                        <div class="card-image">
                            @if (filePreviews.Count > 0)
                            {
                                <img src="@filePreviews.First().Url" alt="preview" class="main-image" />
                                <div class="photo-badge">
                                    <i class="fas fa-camera"></i>
                                    <span>@filePreviews.Count</span>
                                </div>
                            }
                            else
                            {
                                <div class="image-placeholder">
                                    <i class="fas fa-image"></i>
                                    <span>Нет фото</span>
                                </div>
                            }
                            <div class="card-badge">Premium</div>
                        </div>

                        <div class="card-content">
                            <div class="card-header-row">
                                <span class="card-type">@GetPropertyTypeName(model.PropertyTypeId)</span>
                                <span class="card-price">@(model.Price > 0 ? $"{model.Price:N0} ₽" : "—")</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(model.Title))
                            {
                                <h4 class="card-title">@model.Title</h4>
                            }

                            <p class="card-address">
                                <i class="fas fa-map-marker-alt"></i>
                                @(string.IsNullOrWhiteSpace(model.Address) ? "Адрес не указан" : model.Address)
                            </p>

                            <div class="card-stats">
                                <div class="stat-item">
                                    <i class="fas fa-ruler"></i>
                                    <span>@(model.TotalArea > 0 ? $"{model.TotalArea} м²" : "—")</span>
                                </div>
                                <div class="stat-item">
                                    <i class="fas fa-bed"></i>
                                    <span>@(model.Rooms > 0 ? $"{model.Rooms} к." : "—")</span>
                                </div>
                                @if (model.Bathrooms > 0)
                                {
                                    <div class="stat-item">
                                        <i class="fas fa-bath"></i>
                                        <span>@model.Bathrooms</span>
                                    </div>
                                }
                            </div>

                            <div class="card-stats">
                                <div class="stat-item">
                                    <i class="fas fa-layer-group"></i>
                                    <span>@(model.Floor ?? 0)/@(model.TotalFloors ?? 0) эт.</span>
                                </div>
                                @if (model.LivingArea.HasValue)
                                {
                                    <div class="stat-item">
                                        <i class="fas fa-couch"></i>
                                        <span>@model.LivingArea м²</span>
                                    </div>
                                }
                            </div>

                            @if (model.WallMaterialId.HasValue)
                            {
                                <div class="card-extra">
                                    <i class="fas fa-cubes"></i>
                                    <span>@GetWallMaterialName(model.WallMaterialId.Value)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #8b5cf6;
        --primary-dark: #7c3aed;
        --primary-light: #a78bfa;
        --primary-bg: #f5f3ff;
        --bg: #f8fafc;
        --card-bg: #ffffff;
        --text: #1f2937;
        --text-muted: #6b7280;
        --border: #e5e7eb;
        --success: #10b981;
        --error: #ef4444;
        --shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        --shadow-lg: 0 10px 30px rgba(139, 92, 246, 0.15);
    }

    .add-property-page {
        min-height: 100vh;
        background: var(--bg);
        padding: 100px 20px 40px;
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 40px;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0 0 8px;
        color: var(--text);
    }

    .purple-text {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .page-subtitle {
        color: var(--text-muted);
        margin: 0;
        font-size: 1.1rem;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 40px;
    }

    .form-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 40px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group.full-width {
        grid-column: 1 / -1;
    }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text);
    }

    .form-group label i {
        color: var(--primary);
        width: 16px;
    }

    .form-input, .form-select, .form-textarea {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid var(--border);
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s;
        background: var(--card-bg);
        color: var(--text);
    }

    .form-input:focus, .form-select:focus, .form-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px var(--primary-bg);
    }

    .form-select {
        appearance: none;
        cursor: pointer;
    }

    .price-input {
        color: var(--primary);
        font-weight: 700;
    }

    .input-group {
        display: flex;
        align-items: center;
        gap: 0;
    }

    .input-divider {
        padding: 0 8px;
        color: var(--text-muted);
        font-weight: 600;
    }

    .error-text {
        color: var(--error);
        font-size: 0.8rem;
        margin-top: 4px;
    }

    .btn-primary {
        width: 100%;
        padding: 16px 24px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .spinner-small {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .upload-section {
        margin-top: 32px;
        padding-top: 32px;
        border-top: 2px solid var(--border);
    }

    .success-message {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        background: var(--primary-bg);
        border-radius: 12px;
        color: var(--primary);
        font-weight: 600;
        margin-bottom: 24px;
    }

    .upload-area {
        background: var(--bg);
        border: 2px dashed var(--border);
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        transition: all 0.3s;
    }

    .upload-area:hover {
        border-color: var(--primary);
        background: var(--primary-bg);
    }

    .upload-trigger {
        cursor: pointer;
        display: block;
    }

    .upload-trigger i {
        font-size: 3rem;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .upload-text {
        display: block;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
    }

    .upload-hint {
        display: block;
        font-size: 0.875rem;
        color: var(--text-muted);
    }

    .hidden-input {
        display: none;
    }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 12px;
        margin-top: 24px;
    }

    .preview-item {
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid var(--border);
    }

    .preview-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .status-message {
        margin-top: 24px;
        padding: 16px 20px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
    }

    .status-message.success {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success);
    }

    .status-message.error {
        background: rgba(239, 68, 68, 0.1);
        color: var(--error);
    }

    /* Preview Section */
    .preview-section {
        position: sticky;
        top: 120px;
        height: fit-content;
    }

    .preview-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .preview-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 20px;
        color: var(--text);
    }

    .property-card-preview {
        background: var(--card-bg);
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .card-image {
        position: relative;
        height: 200px;
        background: var(--bg);
        overflow: hidden;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        gap: 12px;
    }

    .image-placeholder i {
        font-size: 3rem;
        opacity: 0.5;
    }

    .photo-badge {
        position: absolute;
        bottom: 12px;
        right: 12px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .card-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .card-content {
        padding: 20px;
    }

    .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .card-type {
        font-size: 0.875rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    .card-price {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--primary);
    }

    .card-title {
        font-size: 1.125rem;
        font-weight: 700;
        margin: 0 0 8px;
        color: var(--text);
        line-height: 1.3;
    }

    .card-address {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.875rem;
        margin: 0 0 16px;
    }

    .card-address i {
        color: var(--primary);
    }

    .card-stats {
        display: flex;
        gap: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .stat-item i {
        color: var(--primary);
        width: 16px;
    }

    .card-extra {
        display: flex;
        align-items: center;
        gap: 8px;
        padding-top: 16px;
        margin-top: 16px;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .card-extra i {
        color: var(--primary);
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in {
        animation: fadeIn 0.6s ease forwards;
    }

    @@media (max-width: 1100px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .preview-section {
            position: static;
        }
    }

    @@media (max-width: 600px) {
        .form-card {
            padding: 24px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .page-title {
            font-size: 1.75rem;
        }
    }
</style>

@code {
    private CreatePropertyRequest model = new();
    private int? createdPropertyId;
    private string? statusMessage;
    private bool isProcessing = false;
    private List<FilePreview> filePreviews = new();
    private List<IBrowserFile> originalFiles = new();

    private async Task SubmitProperty()
    {
        if (model.PropertyTypeId == 0)
        {
            statusMessage = "Ошибка: Выберите тип недвижимости";
            return;
        }

        isProcessing = true;
        statusMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("properties", model);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                createdPropertyId = result.GetProperty("propertyId").GetInt32();
            }
            else
            {
                statusMessage = "Ошибка при создании объекта на сервере.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
{
    originalFiles.Clear();
    filePreviews.Clear();
    
    // Получаем все выбранные файлы (максимум 10)
    var maxFiles = 10;
    var files = e.GetMultipleFiles(maxFiles).ToList();
    
    if (!files.Any())
    {
        statusMessage = "Файлы не выбраны";
        return;
    }

    statusMessage = $"Обработка {files.Count} фото...";
    originalFiles.AddRange(files);

    // Обрабатываем каждый файл
    foreach (var file in files)
    {
        try
        {
            // Проверяем, что это изображение
            if (!file.ContentType.StartsWith("image/"))
            {
                continue;
            }

            // Читаем файл в base64 для превью
            using var stream = file.OpenReadStream(15 * 1024 * 1024); // 15 MB max
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            
            filePreviews.Add(new FilePreview 
            { 
                Url = $"data:{file.ContentType};base64,{base64}",
            });
        }
        catch (Exception ex)
        {
            statusMessage = $"Ошибка: {file.Name} - {ex.Message}";
        }
    }

    // Обновляем UI один раз после обработки всех файлов
    StateHasChanged();
    
    if (filePreviews.Any())
    {
        statusMessage = $"Загружено {filePreviews.Count} фото";
    }
}

    private async Task UploadPhotos()
    {
        if (createdPropertyId == null || !originalFiles.Any()) return;

        isProcessing = true;
        statusMessage = "Отправка фотографий...";

        try
        {
            using var content = new MultipartFormDataContent();
            long maxFileSize = 15 * 1024 * 1024;

            foreach (var file in originalFiles)
            {
                var stream = file.OpenReadStream(maxFileSize);
                var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "files", $"{Guid.NewGuid()}_{file.Name}");
            }

            using var http = new HttpClient();
            http.BaseAddress = new Uri("https://localhost:7159/api/");
            var token = TokenStorage.Token;
            if (!string.IsNullOrEmpty(token))
                http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            http.Timeout = TimeSpan.FromMinutes(5);

            var response = await http.PostAsync($"images/upload/{createdPropertyId}", content);
            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Объект успешно опубликован!";
                await Task.Delay(1500);
                ResetAll();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                statusMessage = $"Ошибка сервера {response.StatusCode}: {errorText}";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Сбой: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void ResetAll()
    {
        model = new();
        createdPropertyId = null;
        filePreviews.Clear();
        originalFiles.Clear();
        statusMessage = "";
    }

